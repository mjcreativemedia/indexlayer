---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";

const title = "Services | IndexLayer";
const description =
  "Website builds, SEO rescues, and Search Console audits for local businesses that need cleaner technical foundations and stronger search visibility.";

const services = [
  {
    id: "local-business-websites",
    title: "Local Business Websites",
    path: "/services/local-business-websites/",
    text: "Premium static-first websites for local companies that need fast pages, clear offers, strong trust signals, and stable crawlable HTML.",
  },
  {
    id: "seo-rescue",
    title: "SEO Rescue",
    path: "/services/seo-rescue/",
    text: "Repair work for sites with indexing, canonical, rendering, sitemap, or internal linking problems that make Google confidence harder to earn.",
  },
  {
    id: "search-console-audits",
    title: "Search Console Audits",
    path: "/services/search-console-audits/",
    text: "Plain-English diagnosis of Search Console symptoms, including excluded pages, duplicate canonicals, soft 404s, and crawl mismatches.",
  },
];
---

<BaseLayout title={title} description={description} canonicalPath="/services/">
  <SiteHeader />

  <main class="hub-shell">
    <section class="hub-hero">
      <p class="eyebrow">IndexLayer services</p>
      <h1>Services</h1>
      <p>{description}</p>
    </section>

    <section class="hub-grid" aria-label="Services">
      {services.map((service) => (
        <article id={service.id} class="hub-card">
          <span>{service.path}</span>
          <h2>{service.title}</h2>
          <p>{service.text}</p>
        </article>
      ))}
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .hub-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: 72px 0 94px;
  }

  .hub-hero {
    max-width: 880px;
    margin-bottom: 54px;
  }

  .eyebrow,
  .hub-card span {
    color: var(--green-dark);
    font-size: 0.74rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .eyebrow {
    margin: 0 0 18px;
  }

  h1 {
    margin: 0 0 24px;
    font-size: clamp(3.2rem, 7vw, 6.2rem);
    font-weight: 690;
    letter-spacing: 0;
    line-height: 0.96;
  }

  .hub-hero p,
  .hub-card p {
    color: var(--muted);
    line-height: 1.62;
  }

  .hub-hero p {
    margin: 0;
    font-size: clamp(1.05rem, 1.7vw, 1.24rem);
  }

  .hub-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .hub-card {
    min-height: 300px;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    padding: 26px;
  }

  .hub-card h2 {
    margin: 18px 0 14px;
    font-size: 1.65rem;
    line-height: 1.08;
  }

  .hub-card p {
    margin: 0;
  }

  @media (max-width: 940px) {
    .hub-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hub-shell {
      width: min(100% - 28px, 1180px);
      padding: 48px 0;
    }

    h1 {
      font-size: 3rem;
    }
  }
</style>
