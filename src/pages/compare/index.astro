---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { comparisons } from "../../lib/authority";

const title = "Compare | IndexLayer";
const description =
  "Comparison pages for businesses choosing between website builders, agency stacks, AI site tools, and IndexLayer's stable publishing approach.";

const framework = [
  "Can Google see stable HTML, metadata, canonicals, and internal links?",
  "Can the site expand into services, industries, comparisons, work, and posts without URL drift?",
  "Does the platform make the business easier to understand, or only easier to edit?",
];
---

<BaseLayout title={title} description={description} canonicalPath="/compare/">
  <SiteHeader />

  <main class="hub-shell">
    <section class="hub-hero">
      <p class="eyebrow">IndexLayer comparisons</p>
      <h1>Compare</h1>
      <p>{description}</p>
    </section>

    <section class="authority-band" aria-labelledby="compare-framework-heading">
      <div>
        <p class="eyebrow">Evaluation framework</p>
        <h2 id="compare-framework-heading">Website builders are not the same as publishing systems.</h2>
      </div>
      <p>
        Many tools can produce a good-looking page. The real comparison is whether the final
        site has clean route identity, crawlable content, durable metadata, useful internal
        links, and a structure that can grow without confusing users or search engines.
      </p>
    </section>

    <section class="process-grid" aria-label="Comparison framework">
      {framework.map((item, index) => (
        <article>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <p>{item}</p>
        </article>
      ))}
    </section>

    <section class="hub-grid" aria-label="Comparison pages">
      {comparisons.map((comparison) => (
        <a class="hub-card" href={comparison.path}>
          <span>{comparison.path}</span>
          <h2>{comparison.title}</h2>
          <p>{comparison.description}</p>
        </a>
      ))}
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .hub-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: 72px 0 94px;
  }

  .hub-hero,
  .authority-band {
    max-width: 960px;
  }

  .hub-hero {
    margin-bottom: 54px;
  }

  .eyebrow,
  .hub-card span,
  .process-grid span {
    color: var(--green-dark);
    font-size: 0.74rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .eyebrow {
    margin: 0 0 18px;
  }

  h1 {
    margin: 0 0 24px;
    font-size: clamp(3.2rem, 7vw, 6.2rem);
    font-weight: 690;
    letter-spacing: 0;
    line-height: 0.96;
  }

  h2 {
    margin: 0;
    font-size: clamp(2rem, 3.6vw, 3.6rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .hub-hero p,
  .authority-band p,
  .hub-card p,
  .process-grid p {
    color: var(--muted);
    line-height: 1.62;
  }

  .hub-hero p {
    margin: 0;
    font-size: clamp(1.05rem, 1.7vw, 1.24rem);
  }

  .authority-band {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.7fr);
    gap: 28px;
    align-items: start;
    margin-bottom: 18px;
  }

  .authority-band p {
    margin: 0;
    font-size: 1.04rem;
  }

  .process-grid,
  .hub-grid {
    display: grid;
    gap: 14px;
  }

  .process-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 0 0 46px;
  }

  .process-grid article,
  .hub-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
  }

  .process-grid article {
    padding: 22px;
  }

  .process-grid p {
    margin: 14px 0 0;
  }

  .hub-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .hub-card {
    min-height: 310px;
    display: flex;
    flex-direction: column;
    padding: 26px;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .hub-card:hover {
    border-color: var(--green);
    color: var(--green-dark);
    transform: translateY(-2px);
  }

  .hub-card h2 {
    margin: 18px 0 14px;
    font-size: 1.65rem;
    line-height: 1.08;
  }

  .hub-card p {
    margin: 0;
  }

  @media (max-width: 940px) {
    .authority-band,
    .process-grid,
    .hub-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hub-shell {
      width: min(100% - 28px, 1180px);
      padding: 48px 0;
    }

    h1 {
      font-size: 3rem;
    }
  }
</style>
