---
import { render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import RedirectLayout from "../../layouts/RedirectLayout.astro";
import { getAllPublishedPosts, getEntryPath, getRelatedEntries } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getAllPublishedPosts();

  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: {
      entry,
      related: getRelatedEntries(entry, entries),
    },
  }));
}

const { entry, related } = Astro.props;
const { Content } = await render(entry);
const isMigratedEntry = entry.data.category === "Work" || entry.data.category === "Guide";
---

{isMigratedEntry ? (
  <RedirectLayout from={`/posts/${entry.data.slug}/`} to={getEntryPath(entry)} />
) : (
  <ArticleLayout entry={entry} related={related}>
    <Content />
  </ArticleLayout>
)}
