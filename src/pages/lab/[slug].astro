---
import RedirectLayout from "../../layouts/RedirectLayout.astro";
import { legacyPostRedirects } from "../../lib/legacyRedirects";
import { getAllPublishedPosts, getEntryPath } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getAllPublishedPosts();

  return legacyPostRedirects.lab.map((slug) => ({
    params: { slug },
    props: {
      slug,
      to: getEntryPath(entries.find((entry) => entry.data.slug === slug) ?? slug),
    },
  }));
}

const { slug, to } = Astro.props;
---

<RedirectLayout from={`/lab/${slug}/`} to={to} />
