---
import RedirectLayout from "../../layouts/RedirectLayout.astro";
import { legacyPostRedirects } from "../../lib/legacyRedirects";

export function getStaticPaths() {
  return legacyPostRedirects.guides.map((slug) => ({
    params: { slug },
    props: { slug },
  }));
}

const { slug } = Astro.props;
---

<RedirectLayout from={`/guides/${slug}/`} to={`/posts/${slug}/`} />
