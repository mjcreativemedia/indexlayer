---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { formatDate, getAllPublishedContent, getEntryPath } from "../lib/content";

const title = "IndexLayer | Perfect Local Websites Built for Modern Search";
const description =
  "IndexLayer builds fast, premium local business websites with stable Google visibility, modern search foundations, and transparent technical proof.";

const auditHref = "mailto:hello@indexlayer.pro?subject=Free%20Website%20Audit";

const businessJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "https://indexlayer.pro/#business",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  logo: "https://indexlayer.pro/images/brand/indexlayer-logo.png",
  description,
  areaServed: {
    "@type": "Country",
    name: "United States",
  },
  knowsAbout: [
    "Local business websites",
    "Website rebuilds",
    "Local SEO",
    "Google Search Console",
    "Stable indexing architecture",
    "Website performance",
    "Accessible web design",
  ],
  serviceType: [
    "Local business website builds",
    "Free website audits",
    "Website rebuilds",
    "Google Search Console setup",
    "Local SEO architecture",
    "Website performance improvements",
  ],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://indexlayer.pro/#website",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  publisher: {
    "@id": "https://indexlayer.pro/#business",
  },
};

const websiteSections = [
  {
    eyebrow: "SEO Perfection",
    title: "Built for Google visibility.",
    text: "Clean technical foundations for local websites that need search engines to understand them clearly.",
    visual: "GSC",
    visualType: "google",
    features: ["Complete structured data", "Clean sitemap logic", "Indexable HTML", "Stable canonicals", "Search Console clarity"],
  },
  {
    eyebrow: "Performance",
    title: "Blazing fast.",
    text: "Lightweight pages tuned for clean loading, strong Core Web Vitals, and a faster customer experience.",
    visual: "CWV",
    visualType: "performance",
    features: ["100-speed targets", "Core Web Vitals", "Lightweight pages", "Clean loading", "Fast mobile UX"],
  },
  {
    eyebrow: "Design",
    title: "World-class design.",
    text: "Modern local websites that feel premium, build trust quickly, and help more visitors take action.",
    visual: "UI",
    visualType: "design",
    features: ["Premium UI", "Modern layouts", "Trust signals", "Conversion clarity", "Intentional spacing"],
  },
  {
    eyebrow: "AI search",
    title: "AI-search ready.",
    text: "Structured content and entity signals built for discoverability across modern search surfaces.",
    visual: "LLM",
    visualType: "ai",
    features: ["AI citation paths", "Semantic structure", "Trusted entity signals", "Structured content", "LLM discoverability"],
  },
];

const founderNotes = [
  "Chicago-based",
  "Hands-on builds",
  "Technical SEO",
  "Transparent systems",
];

const latestPosts = (await getAllPublishedContent()).slice(0, 4);
---

<BaseLayout title={title} description={description} jsonLd={[businessJsonLd, websiteJsonLd]}>
  <SiteHeader />

  <main>
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow hero-location">Chicago, USA</p>
        <h1>Perfect local websites.</h1>
        <p class="hero-line">Built for Google, AI search, and real customers.</p>
        <p class="lede">
          Premium design, fast pages, and stable search architecture for local businesses that
          need the web to work clearly.
        </p>
        <div class="actions">
          <a class="button primary" href="/work/">View Our Work</a>
          <a class="button secondary" href={auditHref}>Free Website Audit</a>
        </div>
      </div>

      <aside class="hero-visual" aria-label="Minimal perfect local website visual">
        <div class="hero-system" aria-hidden="true">
          <div class="hero-browser">
            <span class="hero-dot"></span>
            <span class="hero-dot"></span>
            <span class="hero-dot"></span>
            <div class="hero-page-mark"></div>
            <div class="hero-page-line primary"></div>
            <div class="hero-page-line"></div>
            <div class="hero-page-grid">
              <span></span>
              <span></span>
            </div>
          </div>
          <div class="hero-signals">
            <span><i></i>Fast</span>
            <span><i></i>Indexed</span>
            <span><i></i>Trusted</span>
          </div>
        </div>
      </aside>
    </section>

    {websiteSections.map((section, index) => (
      <section class:list={["section", "website-section", index % 2 === 1 && "is-reversed"]}>
        <div class="section-copy">
          <p class="eyebrow">{section.eyebrow}</p>
          <h2>{section.title}</h2>
          <p class="section-lede">{section.text}</p>
          <ul class="feature-pills" aria-label={`${section.title} foundations`}>
            {section.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>
        </div>
        <aside
          class:list={[
            "website-visual",
            section.visualType === "google" && "search-system-visual",
            section.visualType === "performance" && "performance-system-visual",
            section.visualType === "design" && "design-system-visual",
            section.visualType === "ai" && "ai-system-visual",
          ]}
          aria-label={`${section.title} visual concept`}
        >
          {section.visualType === "google" ? (
            <div class="search-system">
              <div class="serp-visual" aria-hidden="true">
                <div class="search-query">tree removal near me</div>
                <div class="serp-results">
                  <span class="serp-line muted"></span>
                  <div class="serp-result featured">
                    <span class="rank-badge">
                      <img src="/images/brand/indexlayer-icon.png" alt="" width="512" height="512" />
                    </span>
                    <span class="result-title"></span>
                    <span class="result-meta"></span>
                  </div>
                  <span class="serp-line"></span>
                  <span class="serp-line short"></span>
                </div>
                <span class="rise-path"></span>
              </div>
            </div>
          ) : section.visualType === "performance" ? (
            <div class="performance-system" aria-hidden="true">
              <span class="perf-badge"><i></i>0.8s</span>
              <div class="assembly-frame">
                <span class="assembly-part nav"></span>
                <span class="assembly-part hero"></span>
                <span class="assembly-part copy"></span>
                <span class="assembly-part card left"></span>
                <span class="assembly-part card right"></span>
              </div>
              <span class="assembly-spark one"></span>
              <span class="assembly-spark two"></span>
            </div>
          ) : section.visualType === "design" ? (
            <div class="design-system" aria-hidden="true">
              <span class="design-guide vertical"></span>
              <span class="design-guide horizontal"></span>
              <div class="design-frame">
                <div class="design-block hero-block"></div>
                <div class="design-columns">
                  <span></span>
                  <span></span>
                </div>
                <div class="design-row">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              </div>
              <span class="balance-node left"></span>
              <span class="balance-node right"></span>
            </div>
          ) : section.visualType === "ai" ? (
            <div class="ai-system" aria-hidden="true">
              <span class="trust-badge"><i></i>Trusted source</span>
              <div class="entity-node">Website</div>
              <div class="agent-node">AI</div>
              <div class="answer-node">Answer</div>
              <span class="ai-flow entity-to-agent"></span>
              <span class="ai-flow agent-to-answer"></span>
            </div>
          ) : (
            <>
              <span class="visual-kicker">Visual concept</span>
              <strong>{section.visual}</strong>
              <div class="visual-tags">
                {section.features.map((feature) => (
                  <span>{feature}</span>
                ))}
              </div>
            </>
          )}
        </aside>
      </section>
    ))}

    <section class="section offer-section">
      <div class="offer-shell">
        <div class="offer-intro">
          <p class="eyebrow">The offer</p>
          <h2>An upgraded website for 2026 and beyond. For less than you pay now.</h2>
          <p>
            Modern local websites with premium design, stable search foundations, Cloudflare
            hosting, and transparent infrastructure — often for less than traditional agency
            retainers.
          </p>
        </div>
        <div class="offer-comparison" role="table" aria-label="Traditional agency compared with IndexLayer">
          <div class="comparison-header" role="row">
            <span role="columnheader">Traditional Agency</span>
            <span role="columnheader">IndexLayer</span>
          </div>
          <div class="comparison-row" role="row">
            <div role="cell">
              <span aria-hidden="true">Traditional Agency</span>
              Slow WordPress stack
            </div>
            <div role="cell">
              <span aria-hidden="true">IndexLayer</span>
              Lightweight HTML-first
            </div>
          </div>
          <div class="comparison-row" role="row">
            <div role="cell">
              <span aria-hidden="true">Traditional Agency</span>
              Monthly retainers
            </div>
            <div role="cell">
              <span aria-hidden="true">IndexLayer</span>
              Simple infrastructure
            </div>
          </div>
          <div class="comparison-row" role="row">
            <div role="cell">
              <span aria-hidden="true">Traditional Agency</span>
              Plugin-heavy
            </div>
            <div role="cell">
              <span aria-hidden="true">IndexLayer</span>
              Clean architecture
            </div>
          </div>
          <div class="comparison-row" role="row">
            <div role="cell">
              <span aria-hidden="true">Traditional Agency</span>
              Weak indexing
            </div>
            <div role="cell">
              <span aria-hidden="true">IndexLayer</span>
              Stable search systems
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="section founder-section">
      <div class="founder-card">
        <div class="founder-copy">
          <p class="eyebrow">Founder</p>
          <div class="founder-identity">
            <div class="founder-photo">
              <img
                src="/images/authors/mitch-argamasilla.jpeg"
                alt="Mitch Argamasilla, founder of IndexLayer"
                width="640"
                height="640"
              />
            </div>
            <h2>Mitch Argamasilla</h2>
          </div>
          <p>
            IndexLayer is built around a simple standard: local websites should look premium,
            load fast, and give search engines a clean technical story.
          </p>
          <div class="founder-note-grid">
            {founderNotes.map((note) => (
              <span>{note}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section posts-strip">
      <div class="section-copy">
        <p class="eyebrow">Proof</p>
        <h2>Selected work.</h2>
        <p class="section-lede">
          Rebuilds, case studies, and technical notes from real local website work.
        </p>
        <a class="text-link" href="/posts/">Read the notes</a>
      </div>
      <div class="post-list">
        {latestPosts.map((entry) => (
          <a class="post-card" href={getEntryPath(entry)}>
            <div class="post-thumb">
              <span>{entry.data.category}</span>
            </div>
            <div class="post-card-copy">
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
              <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section id="contact" class="final-cta">
      <p class="eyebrow">Free website audit</p>
      <h2>Ready for a perfect local website?</h2>
      <a class="button primary" href={auditHref}>Free Website Audit</a>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  main {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 650px;
    margin-bottom: 18px;
    font-size: clamp(3.15rem, 6vw, 5.8rem);
    font-weight: 690;
    letter-spacing: 0;
    line-height: 0.96;
  }

  h2 {
    margin-bottom: 0;
    font-size: clamp(2.05rem, 3.6vw, 3.75rem);
    font-weight: 660;
    letter-spacing: 0;
    line-height: 1.02;
  }

  h3 {
    margin-bottom: 12px;
    font-size: 1.08rem;
    line-height: 1.25;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(420px, 0.82fr);
    gap: 56px;
    align-items: center;
    padding: 88px 0 96px;
  }

  .hero-copy {
    max-width: 820px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--green-dark);
    font-size: 0.74rem;
    font-weight: 760;
    letter-spacing: 0.1em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .hero-location {
    width: fit-content;
    min-height: 32px;
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.56);
    padding: 0 11px;
    letter-spacing: 0.08em;
  }

  .hero-line {
    margin-bottom: 22px;
    color: var(--ink);
    font-size: clamp(1.28rem, 2.4vw, 2.05rem);
    font-weight: 620;
    line-height: 1.1;
  }

  .lede,
  .section-lede {
    max-width: 620px;
    color: var(--muted);
    font-size: clamp(1.02rem, 1.45vw, 1.15rem);
    line-height: 1.58;
  }

  .lede {
    margin-bottom: 32px;
  }

  .hero-visual {
    min-height: 430px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background:
      radial-gradient(circle at 50% 42%, rgba(67, 120, 87, 0.12), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(237, 242, 237, 0.56)),
      var(--soft);
    box-shadow: var(--card-shadow);
  }

  .hero-system {
    min-height: 430px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(24px, 4vw, 44px);
  }

  .hero-browser {
    width: min(78%, 430px);
    min-height: 254px;
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.86);
    box-shadow:
      0 20px 52px rgba(22, 38, 33, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    padding: 20px;
  }

  .hero-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    margin-right: 5px;
    border-radius: 50%;
    background: rgba(22, 38, 33, 0.18);
  }

  .hero-page-mark {
    width: 52px;
    height: 52px;
    margin: 42px auto 24px;
    border-radius: 14px;
    background: var(--ink);
  }

  .hero-page-line {
    width: 48%;
    height: 10px;
    margin: 12px auto 0;
    border-radius: 999px;
    background: rgba(22, 38, 33, 0.1);
  }

  .hero-page-line.primary {
    width: 64%;
    height: 14px;
    background: var(--ink);
  }

  .hero-page-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 30px;
  }

  .hero-page-grid span {
    min-height: 46px;
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(67, 120, 87, 0.12), rgba(255, 255, 255, 0.32)),
      rgba(237, 242, 237, 0.64);
  }

  .hero-signals {
    position: absolute;
    right: clamp(22px, 4vw, 44px);
    bottom: clamp(22px, 4vw, 38px);
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .hero-signals span {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    padding: 5px 10px;
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .hero-signals i {
    width: 7px;
    height: 7px;
    margin-right: 7px;
    border-radius: 50%;
    background: #46d884;
    box-shadow: 0 0 18px rgba(70, 216, 132, 0.72);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .button {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: 6px;
    padding: 0 18px;
    font-weight: 680;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button.primary {
    background: var(--ink);
    color: white;
  }

  .button.primary:hover {
    background: var(--green-dark);
    border-color: var(--green-dark);
  }

  .button.secondary {
    background: rgba(255, 255, 255, 0.42);
  }

  .button.secondary:hover {
    border-color: var(--green);
    color: var(--green-dark);
  }

  .feature-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: -8px 0 0;
    padding: 0;
    color: var(--muted);
    list-style: none;
  }

  .feature-pills li {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 32px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.56);
    padding: 0 11px;
    font-size: 0.86rem;
  }

  .feature-pills li::before,
  .plain-list li::before {
    content: "";
    width: 6px;
    height: 6px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--green);
  }

  .section {
    padding: 94px 0;
    border-top: 1px solid var(--line);
  }

  .section-intro {
    max-width: 820px;
    margin-bottom: 38px;
  }

  .section-intro .section-lede {
    margin-top: 22px;
  }

  .split-section,
  .posts-strip {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(340px, 0.78fr);
    gap: 58px;
    align-items: start;
  }

  .section-copy {
    max-width: 720px;
  }

  .section-copy .section-lede {
    margin-top: 22px;
    margin-bottom: 28px;
  }

  .website-section {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(360px, 0.78fr);
    gap: clamp(34px, 6vw, 76px);
    align-items: center;
  }

  .website-section.is-reversed .section-copy {
    order: 2;
  }

  .website-section.is-reversed .website-visual {
    order: 1;
  }

  .website-visual {
    min-height: 320px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(237, 242, 237, 0.48)),
      var(--soft);
    padding: clamp(20px, 3.4vw, 34px);
  }

  .visual-kicker {
    color: var(--green-dark);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .website-visual strong {
    color: var(--ink);
    font-size: clamp(3.6rem, 8vw, 6.8rem);
    font-weight: 760;
    letter-spacing: 0;
    line-height: 0.92;
  }

  .visual-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .visual-tags span {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    padding: 7px 11px;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .search-system-visual {
    overflow: hidden;
    border-color: var(--line);
    background:
      radial-gradient(circle at 50% 52%, rgba(67, 120, 87, 0.13), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(237, 242, 237, 0.55)),
      var(--soft);
    padding: 0;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.72),
      0 22px 70px rgba(22, 38, 33, 0.14);
  }

  .search-system {
    min-height: 100%;
    padding: clamp(20px, 3.4vw, 34px);
  }

  .serp-visual {
    position: relative;
    min-height: 318px;
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 7px;
    background:
      radial-gradient(circle at 52% 42%, rgba(67, 120, 87, 0.12), transparent 38%),
      rgba(255, 255, 255, 0.42);
  }

  .search-query {
    position: absolute;
    top: 26px;
    left: 50%;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    width: min(72%, 320px);
    min-height: 40px;
    transform: translateX(-50%);
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    padding: 0 18px;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .search-query::before {
    content: "";
    width: 8px;
    height: 8px;
    margin-right: 10px;
    border-radius: 50%;
    background: #46d884;
    box-shadow: 0 0 18px rgba(70, 216, 132, 0.72);
  }

  .serp-results {
    position: absolute;
    left: 50%;
    top: 98px;
    width: min(76%, 350px);
    transform: translateX(-50%);
  }

  .serp-line,
  .serp-result {
    display: block;
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.58);
    box-shadow: 0 12px 30px rgba(22, 38, 33, 0.04);
  }

  .serp-line {
    height: 42px;
    margin-bottom: 12px;
  }

  .serp-line.muted {
    opacity: 0.45;
  }

  .serp-line.short {
    width: 72%;
    opacity: 0.5;
  }

  .serp-result {
    position: relative;
    min-height: 76px;
    margin-bottom: 12px;
    padding: 16px 18px 16px 62px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow:
      0 18px 44px rgba(22, 38, 33, 0.09),
      inset 0 1px 0 rgba(255, 255, 255, 0.76);
    animation: resultRise 4.2s ease-in-out infinite;
  }

  .rank-badge {
    position: absolute;
    left: 16px;
    top: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    transform: translateY(-50%);
