---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { getEntryPath, getPublishedCollection } from "../lib/content";

const title = "IndexLayer | Local Business Websites Built for Search Visibility";
const description =
  "IndexLayer builds fast, trustworthy local service business websites that help Google understand your business and help customers know what to do next.";

const businessJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "https://indexlayer.pro/#business",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  logo: "https://indexlayer.pro/images/brand/indexlayer-mark.png",
  description,
  areaServed: {
    "@type": "Country",
    name: "United States",
  },
  knowsAbout: [
    "Local SEO",
    "Service business websites",
    "Search visibility",
    "Website indexing",
    "Technical SEO",
  ],
  serviceType: [
    "Local business website builds",
    "Website indexing audits",
    "SEO stabilization",
    "Search-ready publishing systems",
  ],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://indexlayer.pro/#website",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  publisher: {
    "@id": "https://indexlayer.pro/#business",
  },
};

const painPoints = [
  "Important pages do not show up in Google.",
  "The site looks nice, but calls are still slow.",
  "Search Console issues keep coming back.",
  "Nobody can explain what is wrong in plain English.",
];

const outcomes = [
  {
    label: "More local visibility",
    text: "Service pages, locations, and offers organized so Google can understand what you do and where you do it.",
    metric: "+ Local reach",
  },
  {
    label: "More qualified calls",
    text: "Clear pages that help nearby customers recognize the right service and take the next step.",
    metric: "+ Better leads",
  },
  {
    label: "Faster websites",
    text: "Lightweight pages that load quickly on phones and feel easy to use when customers are ready to act.",
    metric: "+ Speed",
  },
  {
    label: "Stable indexing",
    text: "A clean publishing foundation that keeps pages consistent instead of confusing search engines.",
    metric: "+ Trust",
  },
];

const caseStudies = [
  {
    name: "Better Call Steve",
    type: "SEO rescue",
    before: "Indexing instability, canonical conflicts, and soft 404 signals.",
    after: "Cleaner page identity, stronger crawl consistency, and a stabilized publishing structure.",
    href: "/case-studies/better-call-steve-seo-rescue/",
  },
  {
    name: "MyCornerstonePlan",
    type: "New build",
    before: "Needed a simple local-service funnel with a search-ready foundation.",
    after: "Fast static pages, clear service paths, clean metadata, and room for future content.",
    href: "/case-studies/mycornerstoneplan-seo-ready-life-insurance-funnel/",
  },
];

const difference = [
  "Clear page structure",
  "Fast HTML-first output",
  "Consistent titles and descriptions",
  "Clean internal links",
  "Accurate sitemap and canonicals",
  "Simple publishing workflow",
];

const process = [
  ["Audit", "Find the search, structure, and indexing problems holding the site back."],
  ["Stabilize", "Fix the foundation so important pages stop sending mixed signals."],
  ["Build", "Create clean service pages and conversion paths around real customer intent."],
  ["Publish", "Launch with a simple system that can keep growing without drifting."],
  ["Monitor", "Watch the signals that matter and keep the site healthy over time."],
];

const latestLab = (await getPublishedCollection("lab")).slice(0, 2);
---

<BaseLayout title={title} description={description} jsonLd={[businessJsonLd, websiteJsonLd]}>
  <SiteHeader />

  <main>
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Websites for local service businesses</p>
        <h1>Beautiful websites are easy. Getting found on Google is harder.</h1>
        <p class="lede">
          IndexLayer builds fast, trustworthy local business websites that help Google
          understand your services and help nearby customers know exactly what to do next.
        </p>
        <div class="actions">
          <a class="button primary" href="/case-studies/">View Case Studies</a>
          <a class="button secondary" href="/guides/stable-indexable-html/">Get A Site Audit</a>
        </div>
      </div>

      <aside class="outcome-visual" aria-label="Local search outcome graphic">
        <div class="search-card">
          <span class="search-label">Google local result</span>
          <strong>Emergency roof repair near me</strong>
          <div class="result-line wide"></div>
          <div class="result-line medium"></div>
          <div class="result-actions">
            <span>Call</span>
            <span>Directions</span>
            <span>Website</span>
          </div>
        </div>
        <div class="phone-card">
          <span>New call</span>
          <strong>Local customer</strong>
          <p>Service page answered the question.</p>
        </div>
        <div class="signal-card">
          <span class="signal-dot"></span>
          <div>
            <strong>Pages Google can trust</strong>
            <p>Clear services, locations, links, and page identity.</p>
          </div>
        </div>
      </aside>
    </section>

    <section class="section problem">
      <div>
        <p class="eyebrow">The problem</p>
        <h2>Most modern websites look good. Many are fragile underneath.</h2>
      </div>
      <div class="pain-list">
        {painPoints.map((point) => (
          <div class="pain-item">
            <span></span>
            <p>{point}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section outcomes">
      <div class="section-intro">
        <p class="eyebrow">What you actually need</p>
        <h2>Clear outcomes for local owners.</h2>
      </div>
      <div class="outcome-grid">
        {outcomes.map((outcome) => (
          <article>
            <span>{outcome.metric}</span>
            <h3>{outcome.label}</h3>
            <p>{outcome.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section proof">
      <div>
        <p class="eyebrow">Proof layer</p>
        <h2>Rescue work and clean builds.</h2>
      </div>
      <div class="case-grid">
        {caseStudies.map((study) => (
          <a class="case-card" href={study.href}>
            <span>{study.type}</span>
            <h3>{study.name}</h3>
            <div>
              <p><strong>Before:</strong> {study.before}</p>
              <p><strong>After:</strong> {study.after}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="section difference">
      <div class="difference-copy">
        <p class="eyebrow">The difference</p>
        <h2>We treat local SEO as a website system, not a checklist.</h2>
        <p>
          Your site needs to be easy for customers and easy for Google. That means every
          service page, location page, link, and search result should point to the same
          clear story about your business.
        </p>
        <a class="text-link" href="/technology/">See the technology behind the method</a>
      </div>
      <div class="system-visual" aria-label="Website system graphic">
        {difference.map((item) => (
          <span>{item}</span>
        ))}
      </div>
    </section>

    <section class="section process">
      <div class="section-intro">
        <p class="eyebrow">Simple process</p>
        <h2>From confusing website problems to a calmer search foundation.</h2>
      </div>
      <div class="process-row">
        {process.map(([name, text], index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{name}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section lab-strip">
      <div>
        <p class="eyebrow">Lab notes</p>
        <h2>Public notes for the technical buyer.</h2>
      </div>
      <div class="note-list">
        {latestLab.map((entry) => (
          <a href={getEntryPath("lab", entry.data.slug)}>{entry.data.title}</a>
        ))}
        <a href="/technology/">Technology and methodology</a>
      </div>
    </section>

    <section class="final-cta">
      <p class="eyebrow">Ready when the site needs to start pulling its weight</p>
      <h2>Built for local businesses that want durable search visibility.</h2>
      <a class="button primary" href="/case-studies/">Start With The Proof</a>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  main {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.72fr);
    gap: 64px;
    align-items: center;
    padding: 42px 0 58px;
  }

  .hero-copy {
    max-width: 820px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--green-dark);
    font-size: 0.78rem;
    font-weight: 760;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin-bottom: 26px;
    max-width: 900px;
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 690;
    letter-spacing: 0;
    line-height: 1;
  }

  h2 {
    margin-bottom: 0;
    font-size: clamp(2rem, 3.8vw, 4.2rem);
    font-weight: 660;
    letter-spacing: 0;
    line-height: 1.03;
  }

  h3 {
    margin-bottom: 12px;
    font-size: 1.08rem;
    line-height: 1.25;
  }

  .lede {
    max-width: 680px;
    margin-bottom: 34px;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.32rem);
    line-height: 1.55;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button {
    min-height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    padding: 0 18px;
    font-weight: 680;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .button.primary {
    background: var(--ink);
    color: white;
  }

  .button.primary:hover {
    background: var(--green-dark);
    border-color: var(--green-dark);
  }

  .button.secondary:hover,
  .text-link:hover {
    border-color: var(--green);
    color: var(--green-dark);
  }

  .outcome-visual {
    position: relative;
    min-height: 520px;
  }

  .search-card,
  .phone-card,
  .signal-card,
  .outcome-grid article,
  .case-card,
  .process-row article {
    background: var(--paper);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .search-card {
    position: absolute;
    top: 0;
    right: 0;
    width: min(100%, 430px);
    padding: 24px;
  }

  .search-label,
  .search-card strong,
  .phone-card span,
  .phone-card strong {
    display: block;
  }

  .search-label {
    margin-bottom: 18px;
    color: var(--muted);
    font-size: 0.84rem;
  }

  .search-card strong {
    margin-bottom: 18px;
    font-size: 1.28rem;
  }

  .result-line {
    height: 10px;
    margin-bottom: 10px;
    background: var(--soft);
  }

  .result-line.wide {
    width: 90%;
  }

  .result-line.medium {
    width: 64%;
  }

  .result-actions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
    margin-top: 22px;
  }

  .result-actions span {
    min-height: 42px;
    display: grid;
    place-items: center;
    background: var(--green-soft);
    color: var(--green-dark);
    font-weight: 700;
  }

  .phone-card {
    position: absolute;
    left: 0;
    top: 190px;
    width: 270px;
    padding: 22px;
    border-color: #cbd8cf;
  }

  .phone-card span {
    margin-bottom: 10px;
    color: var(--green-dark);
    font-size: 0.82rem;
    font-weight: 760;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .phone-card strong {
    margin-bottom: 8px;
    font-size: 1.42rem;
  }

  .phone-card p,
  .signal-card p {
    margin-bottom: 0;
    color: var(--muted);
  }

  .signal-card {
    position: absolute;
    right: 34px;
    bottom: 26px;
    width: min(360px, calc(100% - 34px));
    display: flex;
    gap: 14px;
    padding: 20px;
  }

  .signal-dot {
    width: 14px;
    height: 14px;
    flex: 0 0 auto;
    margin-top: 5px;
    background: var(--green);
    border-radius: 999px;
    box-shadow: 0 0 0 8px var(--green-soft);
  }

  .section {
    padding: 92px 0;
    border-top: 1px solid var(--line);
  }

  .problem,
  .proof,
  .difference,
  .lab-strip {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.8fr);
    gap: 58px;
    align-items: start;
  }

  .pain-list {
    display: grid;
    gap: 10px;
  }

  .pain-item {
    min-height: 68px;
    display: flex;
    align-items: center;
    gap: 14px;
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 16px;
  }

  .pain-item span {
    width: 8px;
    height: 8px;
    flex: 0 0 auto;
    background: var(--green);
    border-radius: 999px;
  }

  .pain-item p {
    margin-bottom: 0;
    color: var(--muted);
    font-weight: 650;
  }

  .section-intro {
    max-width: 760px;
    margin-bottom: 40px;
  }

  .outcome-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .outcome-grid article {
    min-height: 280px;
    padding: 24px;
  }

  .outcome-grid span,
  .case-card > span,
  .process-row span {
    display: inline-flex;
    margin-bottom: 30px;
    color: var(--green-dark);
    background: var(--green-soft);
    padding: 5px 8px;
    font-size: 0.78rem;
    font-weight: 760;
  }

  .outcome-grid p,
  .case-card p,
  .difference-copy p,
  .process-row p {
    color: var(--muted);
  }

  .case-grid {
    display: grid;
    gap: 14px;
  }

  .case-card {
    display: block;
    padding: 24px;
    transition:
      border-color 160ms ease,
      transform 160ms ease;
  }

  .case-card:hover {
    border-color: var(--green);
    transform: translateY(-2px);
  }

  .case-card p {
    margin-bottom: 12px;
  }

  .case-card p:last-child {
    margin-bottom: 0;
  }

  .case-card strong {
    color: var(--ink);
  }

  .difference-copy {
    max-width: 720px;
  }

  .difference-copy p {
    margin: 24px 0;
    font-size: 1.12rem;
    line-height: 1.7;
  }

  .text-link {
    display: inline-flex;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 4px;
    font-weight: 700;
  }

  .system-visual,
  .note-list {
    display: grid;
    gap: 10px;
  }

  .system-visual span,
  .note-list a {
    min-height: 58px;
    display: flex;
    align-items: center;
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 14px 16px;
    font-weight: 680;
  }

  .system-visual span:nth-child(2n) {
    margin-left: 34px;
  }

  .process-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .process-row article {
    min-height: 240px;
    padding: 22px;
  }

  .process-row span {
    margin-bottom: 34px;
  }

  .note-list a:hover {
    border-color: var(--green);
    color: var(--green-dark);
  }

  .final-cta {
    padding: 96px 0 104px;
    border-top: 1px solid var(--line);
    text-align: center;
  }

  .final-cta h2 {
    max-width: 840px;
    margin: 0 auto 28px;
  }

  @media (max-width: 980px) {
    .hero,
    .problem,
    .proof,
    .difference,
    .lab-strip {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      gap: 42px;
      padding-top: 54px;
    }

    .outcome-grid,
    .process-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    main {
      width: min(100% - 28px, 1180px);
    }

    h1 {
      font-size: 2.36rem;
    }

    h2 {
      font-size: 2.12rem;
    }

    .section,
    .final-cta {
      padding: 48px 0;
    }

    .hero {
      padding: 38px 0 44px;
    }

    .lede {
      margin-bottom: 24px;
      font-size: 1rem;
    }

    .outcome-visual {
      min-height: 0;
    }

    .search-card,
    .phone-card,
    .signal-card {
      position: static;
      width: 100%;
      margin-bottom: 12px;
    }

    .search-card {
      padding: 18px;
    }

    .search-label,
    .search-card strong {
      margin-bottom: 12px;
    }

    .phone-card,
    .signal-card {
      display: none;
    }

    .outcome-grid,
    .process-row {
      grid-template-columns: 1fr;
    }

    .outcome-grid article,
    .process-row article {
      min-height: 0;
    }

    .system-visual span:nth-child(2n) {
      margin-left: 0;
    }
  }
</style>
