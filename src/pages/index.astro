---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { formatDate, getAllPublishedContent, getEntryPath } from "../lib/content";

const title = "IndexLayer | Perfect Local Websites Built for Modern Search";
const description =
  "IndexLayer builds fast, premium local business websites with stable Google visibility, modern search foundations, and transparent technical proof.";

const auditHref = "mailto:hello@indexlayer.pro?subject=Free%20Website%20Audit";

const businessJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "https://indexlayer.pro/#business",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  logo: "https://indexlayer.pro/images/brand/indexlayer-logo.png",
  description,
  areaServed: {
    "@type": "Country",
    name: "United States",
  },
  knowsAbout: [
    "Local business websites",
    "Website rebuilds",
    "Local SEO",
    "Google Search Console",
    "Stable indexing architecture",
    "Website performance",
    "Accessible web design",
  ],
  serviceType: [
    "Local business website builds",
    "Free website audits",
    "Website rebuilds",
    "Google Search Console setup",
    "Local SEO architecture",
    "Website performance improvements",
  ],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://indexlayer.pro/#website",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  publisher: {
    "@id": "https://indexlayer.pro/#business",
  },
};

const websiteSections = [
  {
    eyebrow: "SEO Perfection",
    title: "Built for Google visibility.",
    text: "Clean technical foundations for local websites that need search engines to understand them clearly.",
    visual: "GSC",
    visualType: "google",
    features: ["Complete structured data", "Clean sitemap logic", "Indexable HTML", "Stable canonicals", "Search Console clarity"],
  },
  {
    eyebrow: "Performance",
    title: "Blazing fast.",
    text: "Lightweight pages tuned for clean loading, strong Core Web Vitals, and a faster customer experience.",
    visual: "CWV",
    visualType: "performance",
    features: ["100-speed targets", "Core Web Vitals", "Lightweight pages", "Clean loading", "Fast mobile UX"],
  },
  {
    eyebrow: "Design",
    title: "World-class design.",
    text: "Modern local websites that feel premium, build trust quickly, and help more visitors take action.",
    visual: "UI",
    visualType: "design",
    features: ["Premium UI", "Modern layouts", "Trust signals", "Conversion clarity", "Intentional spacing"],
  },
  {
    eyebrow: "AI search",
    title: "AI-search ready.",
    text: "Structured content and entity signals built for discoverability across modern search surfaces.",
    visual: "LLM",
    visualType: "ai",
    features: ["AI citation paths", "Semantic structure", "Trusted entity signals", "Structured content", "LLM discoverability"],
  },
];

const founderNotes = [
  "Chicago-based",
  "Hands-on builds",
  "Technical SEO",
  "Transparent systems",
];

const latestPosts = (await getAllPublishedContent()).slice(0, 4);
---

<BaseLayout title={title} description={description} jsonLd={[businessJsonLd, websiteJsonLd]}>
  <SiteHeader />

  <main>
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow hero-location">Chicago, USA</p>
        <h1>Perfect local websites.</h1>
        <p class="hero-line">Built for Google, AI search, and real customers.</p>
        <p class="lede">
          Premium design, fast pages, and stable search architecture for local businesses that
          need the web to work clearly.
        </p>
        <div class="actions">
          <a class="button primary" href="/work/">View Our Work</a>
          <a class="button secondary" href={auditHref}>Free Website Audit</a>
        </div>
      </div>

      <aside class="hero-visual outcome-visual" aria-label="Customer discovery visual">
        <div class="outcome-scene hero-outcome" aria-hidden="true">
          <div class="customer-search">
            <span></span>
            best local service near me
          </div>
          <div class="hero-site-card">
            <div class="site-card-bar">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="site-card-hero"></div>
            <div class="site-card-line strong"></div>
            <div class="site-card-line"></div>
            <div class="site-card-actions">
              <span></span>
              <span></span>
            </div>
          </div>
          <div class="hero-signals">
            <span><i></i>Fast</span>
            <span><i></i>Indexed</span>
            <span><i></i>Trusted</span>
          </div>
        </div>
      </aside>
    </section>

    {websiteSections.map((section, index) => (
      <section class:list={["section", "website-section", index % 2 === 1 && "is-reversed"]}>
        <div class="section-copy">
          <p class="eyebrow">{section.eyebrow}</p>
          <h2>{section.title}</h2>
          <p class="section-lede">{section.text}</p>
          <ul class="feature-pills" aria-label={`${section.title} foundations`}>
            {section.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>
        </div>
        <aside
          class:list={[
            "website-visual",
            "outcome-visual",
            section.visualType === "google" && "serp-outcome-visual",
            section.visualType === "performance" && "speed-outcome-visual",
            section.visualType === "design" && "design-outcome-visual",
            section.visualType === "ai" && "answer-outcome-visual",
          ]}
          aria-label={`${section.title} visual concept`}
        >
          {section.visualType === "google" ? (
            <div class="outcome-scene serp-outcome" aria-hidden="true">
              <div class="serp-card">
                <div class="serp-search"><span></span>service near me</div>
                <div class="serp-list">
                  <div class="serp-row muted"></div>
                  <div class="serp-business">
                    <span>Best match</span>
                    <strong>Your business</strong>
                    <em>Open now · trusted locally</em>
                  </div>
                  <div class="serp-row"></div>
                  <div class="serp-row short"></div>
                </div>
              </div>
            </div>
          ) : section.visualType === "performance" ? (
            <div class="outcome-scene speed-outcome" aria-hidden="true">
              <div class="phone-preview">
                <span class="outcome-badge"><i></i>Fast</span>
                <div class="phone-speaker"></div>
                <div class="phone-hero"></div>
                <div class="phone-line strong"></div>
                <div class="phone-line"></div>
                <div class="phone-actions">
                  <span></span>
                  <span></span>
                </div>
              </div>
            </div>
          ) : section.visualType === "design" ? (
            <div class="outcome-scene design-outcome" aria-hidden="true">
              <div class="premium-page">
                <div class="premium-hero">
                  <span></span>
                </div>
                <div class="premium-copy">
                  <span class="wide"></span>
                  <span></span>
                </div>
                <div class="trust-strip">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              </div>
            </div>
          ) : section.visualType === "ai" ? (
            <div class="outcome-scene answer-outcome" aria-hidden="true">
              <div class="question-card">Who should I call?</div>
              <div class="answer-card">
                <span class="outcome-badge"><i></i>Referenced</span>
                <strong>Your business</strong>
                <p>A clear local option for this customer.</p>
              </div>
            </div>
          ) : (
            <>
              <span class="visual-kicker">Visual concept</span>
              <strong>{section.visual}</strong>
              <div class="visual-tags">
                {section.features.map((feature) => (
                  <span>{feature}</span>
                ))}
              </div>
            </>
          )}
        </aside>
      </section>
    ))}

    <section class="section offer-section">
      <div class="offer-shell">
        <div class="offer-intro">
          <p class="eyebrow">The offer</p>
          <h2>An upgraded website for 2026 and beyond. For less than you pay now.</h2>
          <p>
            Modern local websites with premium design, stable search foundations, Cloudflare
            hosting, and transparent infrastructure — often for less than traditional agency
            retainers.
          </p>
        </div>
        <div class="offer-comparison" role="table" aria-label="Traditional agency compared with IndexLayer">
          <div class="comparison-header" role="row">
            <span role="columnheader">Traditional Agency</span>
            <span role="columnheader">IndexLayer</span>
          </div>
          <div class="comparison-row" role="row">
            <div role="cell">
              <span aria-hidden="true">Traditional Agency</span>
              Slow WordPress stack
            </div>
            <div role="cell">
              <span aria-hidden="true">IndexLayer</span>
              Lightweight HTML-first
            </div>
          </div>
          <div class="comparison-row" role="row">
            <div role="cell">
              <span aria-hidden="true">Traditional Agency</span>
              Monthly retainers
            </div>
            <div role="cell">
              <span aria-hidden="true">IndexLayer</span>
              Simple infrastructure
            </div>
          </div>
          <div class="comparison-row" role="row">
            <div role="cell">
              <span aria-hidden="true">Traditional Agency</span>
              Plugin-heavy
            </div>
            <div role="cell">
              <span aria-hidden="true">IndexLayer</span>
              Clean architecture
            </div>
          </div>
          <div class="comparison-row" role="row">
            <div role="cell">
              <span aria-hidden="true">Traditional Agency</span>
              Weak indexing
            </div>
            <div role="cell">
              <span aria-hidden="true">IndexLayer</span>
              Stable search systems
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="section founder-section">
      <div class="founder-card">
        <div class="founder-copy">
          <p class="eyebrow">Founder</p>
          <div class="founder-identity">
            <div class="founder-photo">
              <img
                src="/images/authors/mitch-argamasilla.jpeg"
                alt="Mitch Argamasilla, founder of IndexLayer"
                width="640"
                height="640"
              />
            </div>
            <h2>Mitch Argamasilla</h2>
          </div>
          <p>
            IndexLayer is built around a simple standard: local websites should look premium,
            load fast, and give search engines a clean technical story.
          </p>
          <div class="founder-note-grid">
            {founderNotes.map((note) => (
              <span>{note}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section posts-strip">
      <div class="section-copy">
        <p class="eyebrow">Proof</p>
        <h2>Selected work.</h2>
        <p class="section-lede">
          Work, posts, and guides from the publishing system behind IndexLayer.
        </p>
        <a class="text-link" href="/work/">View the proof</a>
      </div>
      <div class="post-list">
        {latestPosts.map((entry) => (
          <a class="post-card" href={getEntryPath(entry)}>
            <div class="post-thumb">
              <span>{entry.data.category}</span>
            </div>
            <div class="post-card-copy">
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
              <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section id="contact" class="final-cta">
      <p class="eyebrow">Free website audit</p>
      <h2>Ready for a perfect local website?</h2>
      <a class="button primary" href={auditHref}>Free Website Audit</a>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  main {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 650px;
    margin-bottom: 18px;
    font-size: clamp(3.15rem, 6vw, 5.8rem);
    font-weight: 690;
    letter-spacing: 0;
    line-height: 0.96;
  }

  h2 {
    margin-bottom: 0;
    font-size: clamp(2.05rem, 3.6vw, 3.75rem);
    font-weight: 660;
    letter-spacing: 0;
    line-height: 1.02;
  }

  h3 {
    margin-bottom: 12px;
    font-size: 1.08rem;
    line-height: 1.25;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(420px, 0.82fr);
    gap: 56px;
    align-items: center;
    padding: 88px 0 96px;
  }

  .hero-copy {
    max-width: 820px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--green-dark);
    font-size: 0.74rem;
    font-weight: 760;
    letter-spacing: 0.1em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .hero-location {
    width: fit-content;
    min-height: 32px;
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.56);
    padding: 0 11px;
    letter-spacing: 0.08em;
  }

  .hero-line {
    margin-bottom: 22px;
    color: var(--ink);
    font-size: clamp(1.28rem, 2.4vw, 2.05rem);
    font-weight: 620;
    line-height: 1.1;
  }

  .lede,
  .section-lede {
    max-width: 620px;
    color: var(--muted);
    font-size: clamp(1.02rem, 1.45vw, 1.15rem);
    line-height: 1.58;
  }

  .lede {
    margin-bottom: 32px;
  }

  .hero-visual {
    min-height: 430px;
  }

  .outcome-visual {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background:
      radial-gradient(circle at 28% 24%, rgba(217, 234, 223, 0.92), transparent 34%),
      radial-gradient(circle at 76% 34%, rgba(67, 120, 87, 0.18), transparent 30%),
      radial-gradient(circle at 52% 82%, rgba(255, 255, 255, 0.86), transparent 42%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(237, 242, 237, 0.62)),
      var(--soft);
    box-shadow: var(--card-shadow);
  }

  .outcome-visual::before {
    content: "";
    position: absolute;
    inset: -34%;
    background:
      radial-gradient(circle at 35% 42%, rgba(255, 255, 255, 0.76), transparent 28%),
      radial-gradient(circle at 65% 54%, rgba(44, 111, 74, 0.13), transparent 30%);
    filter: blur(18px);
    opacity: 0.8;
    transform: rotate(-8deg);
  }

  .outcome-scene {
    position: relative;
    z-index: 1;
    min-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(24px, 4vw, 44px);
  }

  .hero-outcome {
    min-height: 430px;
  }

  .customer-search {
    position: absolute;
    top: clamp(24px, 4vw, 42px);
    left: clamp(22px, 4vw, 42px);
    max-width: min(78%, 330px);
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    padding: 0 16px;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
    box-shadow: 0 16px 44px rgba(20, 24, 22, 0.06);
  }

  .customer-search span,
  .serp-search span {
    width: 9px;
    height: 9px;
    flex: 0 0 auto;
    margin-right: 10px;
    border: 2px solid var(--green);
    border-radius: 50%;
  }

  .hero-site-card,
  .serp-card,
  .phone-preview,
  .premium-page,
  .answer-card {
    border: 1px solid rgba(22, 38, 33, 0.08);
    background: rgba(255, 255, 255, 0.84);
    box-shadow:
      0 24px 58px rgba(22, 38, 33, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .hero-site-card {
    width: min(78%, 420px);
    min-height: 250px;
    border-radius: 14px;
    padding: 18px;
  }

  .site-card-bar {
    display: flex;
    gap: 6px;
    margin-bottom: 30px;
  }

  .site-card-bar span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(22, 38, 33, 0.16);
  }

  .site-card-hero {
    width: 58%;
    height: 58px;
    margin: 0 auto 22px;
    border-radius: 11px;
    background:
      linear-gradient(180deg, rgba(67, 120, 87, 0.16), rgba(255, 255, 255, 0.26)),
      var(--green-soft);
  }

  .site-card-line,
  .phone-line,
  .premium-copy span {
    display: block;
    height: 10px;
    border-radius: 999px;
    background: rgba(22, 38, 33, 0.1);
  }

  .site-card-line {
    width: 52%;
    margin: 11px auto 0;
  }

  .site-card-line.strong,
  .phone-line.strong {
    width: 68%;
    height: 13px;
    background: var(--ink);
  }

  .site-card-actions {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 28px;
  }

  .site-card-actions span,
  .phone-actions span {
    width: 86px;
    height: 30px;
    border-radius: 6px;
    background: var(--ink);
  }

  .site-card-actions span + span,
  .phone-actions span + span {
    border: 1px solid rgba(22, 38, 33, 0.12);
    background: rgba(255, 255, 255, 0.68);
  }

  .hero-signals {
    position: absolute;
    right: clamp(22px, 4vw, 44px);
    bottom: clamp(22px, 4vw, 38px);
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .hero-signals span,
  .outcome-badge {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.76);
    padding: 5px 10px;
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .hero-signals i,
  .outcome-badge i {
    width: 7px;
    height: 7px;
    margin-right: 7px;
    border-radius: 50%;
    background: #46d884;
    box-shadow: 0 0 18px rgba(70, 216, 132, 0.72);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .button {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: 6px;
    padding: 0 18px;
    font-weight: 680;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button.primary {
    background: var(--ink);
    color: white;
  }

  .button.primary:hover {
    background: var(--green-dark);
    border-color: var(--green-dark);
  }

  .button.secondary {
    background: rgba(255, 255, 255, 0.42);
  }

  .button.secondary:hover {
    border-color: var(--green);
    color: var(--green-dark);
  }

  .feature-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: -8px 0 0;
    padding: 0;
    color: var(--muted);
    list-style: none;
  }

  .feature-pills li {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 32px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.56);
    padding: 0 11px;
    font-size: 0.86rem;
  }

  .feature-pills li::before,
  .plain-list li::before {
    content: "";
    width: 6px;
    height: 6px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--green);
  }

  .section {
    padding: 94px 0;
    border-top: 1px solid var(--line);
  }

  .section-intro {
    max-width: 820px;
    margin-bottom: 38px;
  }

  .section-intro .section-lede {
    margin-top: 22px;
  }

  .split-section,
  .posts-strip {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(340px, 0.78fr);
    gap: 58px;
    align-items: start;
  }

  .section-copy {
    max-width: 720px;
  }

  .section-copy .section-lede {
    margin-top: 22px;
    margin-bottom: 28px;
  }

  .website-section {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(360px, 0.78fr);
    gap: clamp(34px, 6vw, 76px);
    align-items: center;
  }

  .website-section.is-reversed .section-copy {
    order: 2;
  }

  .website-section.is-reversed .website-visual {
    order: 1;
  }

  .website-visual {
    min-height: 320px;
  }

  .website-visual .outcome-scene {
    min-height: 320px;
  }

  .serp-card {
    width: min(82%, 380px);
    border-radius: 14px;
    padding: 16px;
  }

  .serp-search {
    min-height: 38px;
    display: flex;
    align-items: center;
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    padding: 0 15px;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .serp-list {
    display: grid;
    gap: 11px;
    margin-top: 16px;
  }

  .serp-row,
  .serp-business {
    border: 1px solid rgba(22, 38, 33, 0.08);
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.58);
  }

  .serp-row {
    min-height: 38px;
  }

  .serp-row.muted {
    opacity: 0.48;
  }

  .serp-row.short {
    width: 72%;
    opacity: 0.58;
  }

  .serp-business {
    display: grid;
    gap: 7px;
    padding: 15px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow:
      0 18px 40px rgba(22, 38, 33, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
  }

  .serp-business span {
    width: fit-content;
    border-radius: 999px;
    background: var(--green-soft);
    padding: 5px 9px;
    color: var(--green-dark);
    font-size: 0.68rem;
    font-style: normal;
    font-weight: 760;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .serp-business strong {
    color: var(--ink);
    font-size: 1rem;
    line-height: 1.15;
  }

  .serp-business em {
    color: var(--muted);
    font-size: 0.8rem;
    font-style: normal;
    font-weight: 650;
  }

  .phone-preview {
    position: relative;
    width: min(58%, 230px);
    min-height: 258px;
    border-radius: 24px;
    padding: 20px 18px 18px;
  }

  .phone-preview .outcome-badge {
    position: absolute;
