---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { formatDate, getAllPublishedContent, getEntryPath } from "../lib/content";

const title = "IndexLayer | Perfect Local Websites Built for Modern Search";
const description =
  "IndexLayer builds fast, premium local business websites with stable Google visibility, modern search foundations, and transparent technical proof.";

const auditHref = "mailto:hello@indexlayer.pro?subject=Free%20Website%20Audit";

const businessJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "https://indexlayer.pro/#business",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  logo: "https://indexlayer.pro/images/brand/indexlayer-logo.png",
  description,
  areaServed: {
    "@type": "Country",
    name: "United States",
  },
  knowsAbout: [
    "Local business websites",
    "Website rebuilds",
    "Local SEO",
    "Google Search Console",
    "Stable indexing architecture",
    "Website performance",
    "Accessible web design",
  ],
  serviceType: [
    "Local business website builds",
    "Free website audits",
    "Website rebuilds",
    "Google Search Console setup",
    "Local SEO architecture",
    "Website performance improvements",
  ],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://indexlayer.pro/#website",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  publisher: {
    "@id": "https://indexlayer.pro/#business",
  },
};

const proofPoints = [
  "100-speed targets",
  "Search-ready architecture",
  "Cloudflare hosting",
  "GSC transparency",
];

const fixes = [
  {
    title: "Fast Pages",
    text: "Lightweight builds tuned for speed, Core Web Vitals, and clean mobile behavior.",
    visual: "100",
  },
  {
    title: "Premium Design",
    text: "Modern interfaces that make local businesses feel credible the moment they load.",
    visual: "UI",
  },
  {
    title: "Stable SEO",
    text: "Clean page identity, metadata, schema, sitemaps, and indexable HTML from day one.",
    visual: "SEO",
  },
];

const visibilityFeatures = [
  "Search Console",
  "Sitemaps",
  "Schema",
  "Local pages",
  "Internal links",
  "Indexing audits",
];

const fragileSignals = [
  "Weak metadata",
  "Duplicate URLs",
  "Thin local pages",
  "Unclear crawl paths",
];

const stableFocus = [
  "Stable HTML",
  "Clean canonicals",
  "Structured metadata",
  "Clear sitemap logic",
];

const founderNotes = [
  "Chicago-based",
  "Hands-on builds",
  "Technical SEO",
  "Transparent systems",
];

const latestPosts = (await getAllPublishedContent()).slice(0, 4);
---

<BaseLayout title={title} description={description} jsonLd={[businessJsonLd, websiteJsonLd]}>
  <SiteHeader />

  <main>
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Modern websites for local search</p>
        <h1>Perfect local websites.</h1>
        <p class="hero-line">Built for Google, AI search, and real customers.</p>
        <p class="lede">
          Premium design, fast pages, and stable search architecture for local businesses that
          need the web to work clearly.
        </p>
        <div class="actions">
          <a class="button primary" href="/work/">View Our Work</a>
          <a class="button secondary" href={auditHref}>Free Website Audit</a>
        </div>
        <ul class="proof-list" aria-label="IndexLayer website foundations">
          {proofPoints.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
      </div>

      <aside class="visual-panel hero-visual image-panel" aria-label="Search visibility dashboard preview">
        <img
          src="/images/home/search-console-abstract.png"
          alt="Abstract search visibility dashboard with charts, indexing signals, and performance panels"
          width="1536"
          height="1024"
        />
      </aside>
    </section>

    <section class="section">
      <div class="fix-grid">
        {fixes.map((fix) => (
          <article class="card fix-card">
            <span class="fix-visual">{fix.visual}</span>
            <h3>{fix.title}</h3>
            <p>{fix.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section split-section">
      <div class="section-copy">
        <p class="eyebrow">Google visibility</p>
        <h2>Google visibility, built in.</h2>
        <p class="section-lede">
          Every build ships with the search fundamentals most local websites are missing.
        </p>
        <div class="feature-grid">
          {visibilityFeatures.map((feature) => (
            <span>{feature}</span>
          ))}
        </div>
      </div>
      <aside class="visual-panel gsc-visual image-panel" aria-label="Google Search Console style visibility snapshot">
        <img
          src="/images/home/search-console-abstract.png"
          alt="Abstract analytics interface showing search visibility charts and page health indicators"
          width="1536"
          height="1024"
        />
      </aside>
    </section>

    <section class="section problem-section">
      <div class="section-intro">
        <p class="eyebrow">The difference</p>
        <h2>Good-looking is not the same as search-ready.</h2>
        <p class="section-lede">
          A modern site still needs stable page identity, clean metadata, and crawlable structure.
        </p>
      </div>
      <div class="comparison-visual image-panel">
        <img
          src="/images/home/website-stability-comparison.png"
          alt="Side-by-side website infrastructure comparison showing fragile signals next to a stable search-ready system"
          width="1536"
          height="1024"
        />
      </div>
      <div class="problem-grid compact">
        <div class="card">
          <h3>What breaks</h3>
          <ul class="plain-list">
            {fragileSignals.map((signal) => (
              <li>{signal}</li>
            ))}
          </ul>
        </div>
        <div class="card focus-card">
          <h3>What we stabilize</h3>
          <ul class="plain-list">
            {stableFocus.map((focus) => (
              <li>{focus}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section offer-section">
      <div class="offer-card">
        <p class="eyebrow">The offer</p>
        <h2>A better website, usually for less.</h2>
        <p>
          A premium local website with speed, SEO structure, hosting, and the functionality you
          actually need. Hosted on Cloudflare, documented clearly, and built to outperform the
          bloated setup many businesses already pay for.
        </p>
        <div class="offer-note">
          <span>Target outcome</span>
          <strong>Beautiful design. 100-speed targets. Stable search foundations. Around 50% less than many current website retainers.</strong>
        </div>
      </div>
    </section>

    <section id="about" class="section founder-section">
      <div class="founder-card">
        <div class="founder-copy">
          <p class="eyebrow">Founder</p>
          <div class="founder-identity">
            <div class="founder-photo">
              <img
                src="/images/authors/mitch-argamasilla.jpeg"
                alt="Mitch Argamasilla, founder of IndexLayer"
                width="640"
                height="640"
              />
            </div>
            <h2>Mitch Argamasilla</h2>
          </div>
          <p>
            IndexLayer is built around a simple standard: local websites should look premium,
            load fast, and give search engines a clean technical story.
          </p>
          <div class="founder-note-grid">
            {founderNotes.map((note) => (
              <span>{note}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section posts-strip">
      <div class="section-copy">
        <p class="eyebrow">Proof</p>
        <h2>Selected work.</h2>
        <p class="section-lede">
          Rebuilds, case studies, and technical notes from real local website work.
        </p>
        <a class="text-link" href="/posts/">Read the notes</a>
      </div>
      <div class="post-list">
        {latestPosts.map((entry) => (
          <a class="post-card" href={getEntryPath(entry)}>
            <div class="post-thumb">
              <span>{entry.data.category}</span>
            </div>
            <div class="post-card-copy">
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
              <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section id="contact" class="final-cta">
      <p class="eyebrow">Free website audit</p>
      <h2>Ready for a perfect local website?</h2>
      <a class="button primary" href={auditHref}>Free Website Audit</a>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  main {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 650px;
    margin-bottom: 18px;
    font-size: clamp(3.15rem, 6vw, 5.8rem);
    font-weight: 690;
    letter-spacing: 0;
    line-height: 0.96;
  }

  h2 {
    margin-bottom: 0;
    font-size: clamp(2.05rem, 3.6vw, 3.75rem);
    font-weight: 660;
    letter-spacing: 0;
    line-height: 1.02;
  }

  h3 {
    margin-bottom: 12px;
    font-size: 1.08rem;
    line-height: 1.25;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(420px, 0.82fr);
    gap: 56px;
    align-items: center;
    padding: 88px 0 96px;
  }

  .hero-copy {
    max-width: 820px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--green-dark);
    font-size: 0.74rem;
    font-weight: 760;
    letter-spacing: 0.1em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .hero-line {
    margin-bottom: 22px;
    color: var(--ink);
    font-size: clamp(1.28rem, 2.4vw, 2.05rem);
    font-weight: 620;
    line-height: 1.1;
  }

  .lede,
  .section-lede {
    max-width: 620px;
    color: var(--muted);
    font-size: clamp(1.02rem, 1.45vw, 1.15rem);
    line-height: 1.58;
  }

  .lede {
    margin-bottom: 32px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .button {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: 6px;
    padding: 0 18px;
    font-weight: 680;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button.primary {
    background: var(--ink);
    color: white;
  }

  .button.primary:hover {
    background: var(--green-dark);
    border-color: var(--green-dark);
  }

  .button.secondary {
    background: rgba(255, 255, 255, 0.42);
  }

  .button.secondary:hover {
    border-color: var(--green);
    color: var(--green-dark);
  }

  .proof-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    color: var(--muted);
    list-style: none;
  }

  .proof-list li {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 32px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.56);
    padding: 0 11px;
    font-size: 0.86rem;
  }

  .proof-list li::before,
  .plain-list li::before {
    content: "";
    width: 6px;
    height: 6px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--green);
  }

  .section {
    padding: 94px 0;
    border-top: 1px solid var(--line);
  }

  .section-intro {
    max-width: 820px;
    margin-bottom: 38px;
  }

  .section-intro .section-lede {
    margin-top: 22px;
  }

  .split-section,
  .posts-strip {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(340px, 0.78fr);
    gap: 58px;
    align-items: start;
  }

  .section-copy {
    max-width: 720px;
  }

  .section-copy .section-lede {
    margin-top: 22px;
    margin-bottom: 28px;
  }

  .card,
  .visual-panel,
  .offer-card,
  .founder-card,
  .post-card {
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    box-shadow: var(--card-shadow);
  }

  .fix-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .fix-card {
    min-height: 250px;
    display: flex;
    flex-direction: column;
    padding: 26px;
  }

  .fix-visual {
    width: 62px;
    height: 62px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(217, 234, 223, 0.8), rgba(255, 255, 255, 0.75)),
      var(--soft);
    color: var(--green-dark);
    font-size: 1.05rem;
    font-weight: 760;
  }

  .fix-card p,
  .post-card p,
  .founder-copy p,
  .offer-card p {
    color: var(--muted);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .feature-grid span,
  .founder-note-grid span {
    min-height: 42px;
    display: flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.56);
    padding: 10px 12px;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .visual-panel {
    padding: 18px;
  }

  .image-panel {
    overflow: hidden;
  }

  .image-panel img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 7px;
  }

  .hero-visual img {
    aspect-ratio: 1.28;
    object-fit: cover;
  }

  .comparison-visual {
    margin-bottom: 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: rgba(255, 255, 255, 0.78);
    box-shadow: var(--card-shadow);
    padding: 12px;
  }

  .panel-label {
    margin-bottom: 14px;
    color: var(--green-dark);
    font-size: 0.73rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mock-browser,
  .gsc-shell {
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(237, 242, 237, 0.7), rgba(255, 255, 255, 0.82)),
      var(--paper);
    overflow: hidden;
  }

  .browser-bar {
    display: flex;
    gap: 6px;
    border-bottom: 1px solid var(--line);
    padding: 12px;
  }

  .browser-bar span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--line);
  }

  .mock-layout {
    display: grid;
    gap: 12px;
    padding: 14px;
  }

  .mock-site,
  .visibility-card,
  .mock-metrics > div,
  .gsc-row {
    border: 1px solid var(--line);
    border-radius: 7px;
    background: rgba(255, 255, 255, 0.72);
  }

  .mock-site {
    min-height: 180px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 18px;
  }

  .mock-site span,
  .mock-metrics span,
  .visibility-card span,
  .gsc-row span,
  .offer-note span {
    color: var(--muted);
    font-size: 0.82rem;
  }

  .mock-site strong {
    max-width: 250px;
    font-size: 1.65rem;
    line-height: 1.06;
  }

  .mock-site div {
    width: 46%;
    height: 10px;
    border-radius: 999px;
    background: var(--green-soft);
  }

  .mock-metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .mock-metrics > div {
    display: grid;
    gap: 10px;
    padding: 14px;
  }

  .mock-metrics strong {
    font-size: 1.55rem;
  }

  .visibility-card {
    margin: 0 14px 14px;
    padding: 14px;
  }

  .mini-chart {
    height: 92px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    align-items: end;
    margin-top: 16px;
  }

  .mini-chart i {
    display: block;
    border-radius: 999px 999px 0 0;
    background: var(--green-soft);
  }

  .mini-chart i:nth-child(1) {
    height: 30%;
  }

  .mini-chart i:nth-child(2) {
    height: 48%;
  }

  .mini-chart i:nth-child(3) {
    height: 42%;
  }

  .mini-chart i:nth-child(4) {
    height: 70%;
  }

  .mini-chart i:nth-child(5) {
    height: 88%;
    background: var(--green);
  }

  .gsc-shell {
    display: grid;
    gap: 10px;
    padding: 14px;
  }

  .gsc-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 14px;
  }

  .gsc-line {
    height: 120px;
    border: 1px solid var(--line);
    border-radius: 7px;
    background:
      linear-gradient(135deg, transparent 44%, var(--green-soft) 44%, var(--green-soft) 49%, transparent 49%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(237, 242, 237, 0.45));
  }

  .problem-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(0, 1fr);
    gap: 14px;
  }

  .problem-grid.compact {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .problem-grid .card {
    padding: 26px;
  }

  .plain-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    color: var(--muted);
    list-style: none;
  }

  .plain-list li {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  blockquote {
    margin: 28px 0 0;
    border-left: 2px solid var(--green);
    padding-left: 16px;
    color: var(--ink);
    font-size: 1.24rem;
    line-height: 1.35;
  }

  .offer-section {
    padding: 78px 0;
  }

  .offer-card {
    max-width: 980px;
    margin: 0 auto;
    padding: clamp(28px, 5vw, 58px);
  }

  .offer-card > p {
    max-width: 760px;
    margin-top: 24px;
    font-size: 1.1rem;
    line-height: 1.65;
  }

  .offer-note {
    margin-top: 34px;
    border-top: 1px solid var(--line);
    padding-top: 26px;
  }

  .offer-note strong {
    max-width: 760px;
    display: block;
    margin: 8px 0 12px;
    font-size: clamp(1.35rem, 2.7vw, 2.35rem);
    font-weight: 640;
    line-height: 1.12;
  }

  .offer-note p {
    margin-bottom: 0;
  }

  .founder-card {
    max-width: 720px;
    margin: 0 auto;
    padding: 28px;
  }

  .founder-photo {
    width: 74px;
    flex: 0 0 74px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: var(--soft);
  }

  .founder-photo img {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    height: auto;
    object-fit: cover;
  }

  .founder-copy {
    padding: 0;
  }

  .founder-identity {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 18px;
  }

  .founder-identity h2 {
    font-size: clamp(1.75rem, 3vw, 2.65rem);
  }

  .founder-copy p {
    line-height: 1.62;
  }

  .founder-note-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    margin: 24px 0 0;
  }

  .founder-quote {
    margin-bottom: 0;
    color: var(--ink);
    font-weight: 660;
  }

  .post-list {
    display: grid;
    gap: 12px;
  }

  .post-card {
    display: grid;
    grid-template-columns: 132px minmax(0, 1fr);
    min-height: 156px;
    overflow: hidden;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .post-thumb {
    min-height: 156px;
    display: flex;
    align-items: flex-start;
    padding: 18px;
    background:
      linear-gradient(180deg, rgba(217, 234, 223, 0.9), rgba(237, 242, 237, 0.7)),
      var(--soft);
  }

  .post-thumb span {
    display: inline-flex;
    color: var(--green-dark);
    background: rgba(255, 255, 255, 0.72);
    border-radius: 5px;
    padding: 5px 8px;
    font-size: 0.7rem;
    font-weight: 760;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .post-card-copy {
    display: flex;
    flex-direction: column;
    padding: 20px;
  }

  .post-card h3 {
    margin-bottom: 10px;
    font-size: 1.1rem;
  }

  .post-card p {
    margin-bottom: 18px;
    line-height: 1.5;
  }

  .post-card time {
    margin-top: auto;
    color: var(--muted);
    font-size: 0.84rem;
  }

  .post-card:hover {
    border-color: var(--green);
    color: var(--green-dark);
    transform: translateY(-2px);
  }

  .text-link {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    border-bottom: 1px solid var(--green);
    color: var(--green-dark);
    font-weight: 700;
  }

  .final-cta {
    padding: 96px 0 104px;
    border-top: 1px solid var(--line);
    text-align: center;
  }

  .final-cta h2 {
    max-width: 900px;
    margin: 0 auto 28px;
  }

  .final-cta .eyebrow {
    margin-bottom: 16px;
  }

  @media (max-width: 1100px) {
    .hero,
    .split-section,
    .posts-strip {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 56px;
    }

    .hero-visual,
    .gsc-visual {
      max-width: 760px;
    }

    .fix-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
