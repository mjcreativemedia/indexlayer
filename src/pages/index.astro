---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { formatDate, getAllPublishedContent, getEntryPath } from "../lib/content";

const title = "IndexLayer | Local Business Websites Built for Search Visibility";
const description =
  "IndexLayer builds fast, trustworthy local service business websites that help Google understand your business and help customers know what to do next.";

const businessJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "https://indexlayer.pro/#business",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  logo: "https://indexlayer.pro/images/brand/indexlayer-mark.png",
  description,
  areaServed: {
    "@type": "Country",
    name: "United States",
  },
  knowsAbout: [
    "Local SEO",
    "Service business websites",
    "Search visibility",
    "Website performance",
    "Google visibility",
  ],
  serviceType: [
    "Local business website builds",
    "Website audits",
    "Local SEO cleanup",
    "Search-ready service pages",
  ],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://indexlayer.pro/#website",
  name: "IndexLayer",
  url: "https://indexlayer.pro/",
  publisher: {
    "@id": "https://indexlayer.pro/#business",
  },
};

const outcomes = [
  {
    label: "More calls",
    text: "Clear service pages built around real searches.",
  },
  {
    label: "Faster websites",
    text: "Pages that load quickly and feel easy to use.",
  },
  {
    label: "Better visibility",
    text: "Help Google understand your business clearly.",
  },
  {
    label: "Easier growth",
    text: "A clean foundation that is easy to expand later.",
  },
];

const caseStudies = [
  {
    name: "Better Call Steve",
    type: "SEO rescue",
    text: "Fixed confusing page signals so the site could be easier for Google to understand.",
    href: "/posts/better-call-steve-seo-rescue/",
  },
  {
    name: "MyCornerstonePlan",
    type: "New build",
    text: "Built a fast local-service funnel with clear pages and room to grow.",
    href: "/posts/mycornerstoneplan-seo-ready-life-insurance-funnel/",
  },
];

const process = [
  ["Audit", "Find what is holding the site back."],
  ["Fix", "Clean up structure and visibility issues."],
  ["Build", "Create clear service and location pages."],
  ["Launch", "Publish fast, stable pages."],
  ["Grow", "Add content and improve over time."],
];

const latestPosts = (await getAllPublishedContent()).slice(0, 4);
---

<BaseLayout title={title} description={description} jsonLd={[businessJsonLd, websiteJsonLd]}>
  <SiteHeader />

  <main>
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Websites for local service businesses</p>
        <h1>Beautiful websites. Clear Google visibility.</h1>
        <p class="lede">
          We build local business websites that load fast, explain your services clearly,
          and help nearby customers find you.
        </p>
        <div class="actions">
          <a class="button primary" href="#contact">Get A Site Audit</a>
          <a class="button secondary" href="/work/">View Work</a>
        </div>
      </div>

      <aside class="outcome-visual" aria-label="Local search outcome graphic">
        <img
          src="/images/home/hero-search-visibility.png"
          alt="A local business website turning into a Google search result and a new customer call."
          width="1536"
          height="1024"
        />
      </aside>
    </section>

    <section class="section outcomes">
      <div class="section-intro">
        <h2>Better outcomes.</h2>
      </div>
      <div class="outcome-grid">
        {outcomes.map((outcome) => (
          <article>
            <h3>{outcome.label}</h3>
            <p>{outcome.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section proof">
      <div>
        <h2>Built clean from day one. Or fixed after things broke.</h2>
      </div>
      <div class="case-grid">
        {caseStudies.map((study) => (
          <a class="case-card" href={study.href}>
            <span>{study.type}</span>
            <h3>{study.name}</h3>
            <p>{study.text}</p>
          </a>
        ))}
      </div>
    </section>

    <section id="about" class="section process">
      <div class="section-intro">
        <h2>Simple process.</h2>
      </div>
      <div class="process-row">
        {process.map(([name, text], index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{name}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section posts-strip">
      <div>
        <h2>Latest posts.</h2>
      </div>
      <div class="post-list">
        {latestPosts.map((entry) => (
          <a class="post-card" href={getEntryPath(entry)}>
            <div class="post-thumb">
              <span>{entry.data.category}</span>
            </div>
            <div class="post-card-copy">
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
              <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section id="contact" class="final-cta">
      <h2>Ready for a website that actually helps your business grow?</h2>
      <a class="button primary" href="mailto:hello@indexlayer.pro?subject=Site%20Audit">Get A Site Audit</a>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  main {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(500px, 0.75fr);
    gap: 48px;
    align-items: center;
    padding: 42px 0 58px;
  }

  .hero-copy {
    max-width: 820px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--green-dark);
    font-size: 0.78rem;
    font-weight: 760;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin-bottom: 26px;
    max-width: 900px;
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 690;
    letter-spacing: 0;
    line-height: 1;
  }

  h2 {
    margin-bottom: 0;
    font-size: clamp(2rem, 3.8vw, 4.2rem);
    font-weight: 660;
    letter-spacing: 0;
    line-height: 1.03;
  }

  h3 {
    margin-bottom: 12px;
    font-size: 1.08rem;
    line-height: 1.25;
  }

  .lede {
    max-width: 680px;
    margin-bottom: 34px;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.32rem);
    line-height: 1.55;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button {
    min-height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    padding: 0 18px;
    font-weight: 680;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .button.primary {
    background: var(--ink);
    color: white;
  }

  .button.primary:hover {
    background: var(--green-dark);
    border-color: var(--green-dark);
  }

  .button.secondary:hover {
    border-color: var(--green);
    color: var(--green-dark);
  }

  .outcome-visual {
    width: min(620px, calc(100% + 100px));
    margin-left: -36px;
  }

  .outcome-grid article,
  .case-card,
  .process-row article,
  .post-card {
    background: var(--paper);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .outcome-visual img {
    display: block;
    width: 100%;
    height: auto;
  }

  .section {
    padding: 92px 0;
    border-top: 1px solid var(--line);
  }

  .proof,
  .posts-strip {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.8fr);
    gap: 58px;
    align-items: start;
  }

  .section-intro {
    max-width: 760px;
    margin-bottom: 40px;
  }

  .outcome-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .outcome-grid article {
    min-height: 190px;
    padding: 24px;
  }

  .case-card > span,
  .process-row span {
    display: inline-flex;
    margin-bottom: 30px;
    color: var(--green-dark);
    background: var(--green-soft);
    padding: 5px 8px;
    font-size: 0.78rem;
    font-weight: 760;
  }

  .outcome-grid p,
  .case-card p,
  .process-row p {
    color: var(--muted);
  }

  .case-grid {
    display: grid;
    gap: 14px;
  }

  .case-card {
    display: block;
    padding: 24px;
    transition:
      border-color 160ms ease,
      transform 160ms ease;
  }

  .case-card:hover {
    border-color: var(--green);
    transform: translateY(-2px);
  }

  .case-card p {
    margin-bottom: 12px;
  }

  .case-card p:last-child {
    margin-bottom: 0;
  }

  .post-list {
    display: grid;
    gap: 12px;
  }

  .post-card {
    display: grid;
    grid-template-columns: 132px minmax(0, 1fr);
    min-height: 156px;
    overflow: hidden;
    transition:
      border-color 160ms ease,
      transform 160ms ease;
  }

  .post-thumb {
    min-height: 156px;
    display: flex;
    align-items: flex-start;
    padding: 18px;
    background:
      linear-gradient(180deg, rgba(217, 234, 223, 0.9), rgba(237, 242, 237, 0.7)),
      var(--soft);
  }

  .post-thumb span {
    display: inline-flex;
    color: var(--green-dark);
    background: rgba(255, 255, 255, 0.72);
    padding: 5px 8px;
    font-size: 0.7rem;
    font-weight: 760;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .post-card-copy {
    display: flex;
    flex-direction: column;
    padding: 20px;
  }

  .post-card h3 {
    margin-bottom: 10px;
    font-size: 1.1rem;
  }

  .post-card p {
    margin-bottom: 18px;
    color: var(--muted);
    line-height: 1.5;
  }

  .post-card time {
    margin-top: auto;
    color: var(--muted);
    font-size: 0.84rem;
  }

  .process-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .process-row article {
    min-height: 240px;
    padding: 22px;
  }

  .process-row span {
    margin-bottom: 34px;
  }

  .post-card:hover {
    border-color: var(--green);
    color: var(--green-dark);
    transform: translateY(-2px);
  }

  .final-cta {
    padding: 96px 0 104px;
    border-top: 1px solid var(--line);
    text-align: center;
  }

  .final-cta h2 {
    max-width: 840px;
    margin: 0 auto 28px;
  }

  @media (max-width: 1100px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .outcome-visual {
      width: min(100%, 760px);
      margin-left: 0;
    }
  }

  @media (max-width: 980px) {
    .hero,
    .proof,
    .posts-strip {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      gap: 42px;
      padding-top: 54px;
    }

    .outcome-visual {
      width: min(100%, 760px);
      margin-left: 0;
    }

    .outcome-grid,
    .process-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    main {
      width: min(100% - 28px, 1180px);
    }

    h1 {
      font-size: 2.36rem;
    }

    h2 {
      font-size: 2.12rem;
    }

    .section,
    .final-cta {
      padding: 48px 0;
    }

    .hero {
      padding: 38px 0 44px;
    }

    .lede {
      margin-bottom: 24px;
      font-size: 1rem;
    }

    .outcome-grid,
    .process-row {
      grid-template-columns: 1fr;
    }

    .post-card {
      grid-template-columns: 1fr;
    }

    .post-thumb {
      min-height: 86px;
    }

    .outcome-grid article,
    .process-row article {
      min-height: 0;
    }

  }
</style>
