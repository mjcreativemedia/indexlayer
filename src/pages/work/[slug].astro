---
import { render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getAllPublishedPosts, getRelatedEntries } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getAllPublishedPosts();
  const workEntries = entries.filter((entry) => entry.data.category === "Work");

  return workEntries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: {
      entry,
      related: getRelatedEntries(entry, entries),
    },
  }));
}

const { entry, related } = Astro.props;
const { Content } = await render(entry);
---

<ArticleLayout entry={entry} related={related}>
  <Content />
</ArticleLayout>
