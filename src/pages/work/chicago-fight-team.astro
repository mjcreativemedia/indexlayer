---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";

const title = "Chicago Fight Team | IndexLayer Work";
const description =
  "A homepage rebuild preview for Chicago Fight Team, focused on preserving real gym authority while improving clarity, mobile presentation, and local trust.";
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/work/chicago-fight-team/"
  ogImage="/images/work/chicago-fight-team/training-room-wide.jpeg"
>
  <SiteHeader />

  <main class="work-detail">
    <section class="work-hero">
      <p class="eyebrow">Work</p>
      <h1>Chicago Fight Team</h1>
      <p>
        A homepage rebuild concept for an established MMA, Brazilian Jiu-Jitsu,
        and Muay Thai gym in Justice, Illinois.
      </p>
      <div class="actions">
        <a class="button primary" href="/preview/chicago-fight-team/">View Live Preview</a>
        <a class="button secondary" href="/work/chicago-fight-team-homepage-rebuild/">Read Breakdown</a>
      </div>
    </section>

    <section class="project-media" aria-label="Chicago Fight Team homepage preview">
      <img src="/images/work/chicago-fight-team/training-room-wide.jpeg" alt="Chicago Fight Team training room" />
    </section>

    <section class="project-grid" aria-label="Project overview">
      <article>
        <span>Context</span>
        <p>
          The gym already has real authority: coaches, fighters, history,
          training footage, and a physical local presence.
        </p>
      </article>
      <article>
        <span>Direction</span>
        <p>
          The redesign removes campaign-style copy and presents the gym through
          direct language, real media, and cleaner mobile structure.
        </p>
      </article>
      <article>
        <span>Preview</span>
        <p>
          The standalone route shows the rebuilt homepage without article
          framing, so it can be reviewed like a real client site.
        </p>
      </article>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .work-detail {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: 72px 0 94px;
  }

  .work-hero {
    max-width: 860px;
    margin-bottom: 42px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--green-dark);
    font-size: 0.74rem;
    font-weight: 760;
    letter-spacing: 0.1em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 22px;
    font-size: clamp(3.2rem, 7vw, 6.2rem);
    font-weight: 690;
    letter-spacing: 0;
    line-height: 0.96;
  }

  .work-hero p {
    max-width: 720px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.7vw, 1.24rem);
    line-height: 1.62;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    border: 1px solid var(--line);
    border-radius: var(--radius-control);
    padding: 0 16px;
    font-weight: 720;
  }

  .button.primary {
    border-color: var(--ink);
    background: var(--ink);
    color: white;
  }

  .button.secondary {
    background: var(--card-bg);
    color: var(--ink);
  }

  .project-media {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: var(--soft);
    box-shadow: var(--card-shadow);
  }

  .project-media img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    filter: grayscale(1) contrast(1.04);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 14px;
  }

  .project-grid article {
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    padding: 24px;
  }

  .project-grid span {
    display: block;
    margin-bottom: 12px;
    color: var(--green-dark);
    font-size: 0.76rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-grid p {
    margin: 0;
    color: var(--muted);
    line-height: 1.58;
  }

  @media (max-width: 820px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .work-detail {
      width: min(100% - 28px, 1180px);
      padding: 48px 0;
    }

    h1 {
      font-size: 3rem;
    }
  }
</style>
