---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";

const title = "Brand | IndexLayer";
const description = "A lightweight guide to the IndexLayer logo, mark, and core brand colors.";

const colors = [
  { name: "Ink", value: "#141816", token: "--ink" },
  { name: "Green", value: "#2c6f4a", token: "--green" },
  { name: "Deep Green", value: "#174d34", token: "--green-dark" },
  { name: "Soft Green", value: "#d9eadf", token: "--green-soft" },
  { name: "Background", value: "#f7f8f5", token: "--bg" },
  { name: "Line", value: "#dfe5de", token: "--line" },
];
---

<BaseLayout title={title} description={description} canonicalPath="/brand/">
  <SiteHeader />

  <main class="brand-shell">
    <section class="brand-hero">
      <p class="eyebrow">Brand guide</p>
      <h1>IndexLayer brand assets.</h1>
      <p>
        Minimal marks, technical calm, and a restrained green system for local websites built with
        infrastructure-level care.
      </p>
    </section>

    <section class="asset-section" aria-labelledby="logos-heading">
      <div class="section-copy">
        <p class="eyebrow">Logo</p>
        <h2 id="logos-heading">Primary marks.</h2>
      </div>
      <div class="asset-grid">
        <article class="asset-card logo-card">
          <span>Primary logo</span>
          <img src="/images/brand/indexlayer-logo.png" alt="IndexLayer logo" width="951" height="229" />
        </article>
        <article class="asset-card icon-card">
          <span>Icon</span>
          <img src="/images/brand/indexlayer-icon.png" alt="IndexLayer icon" width="512" height="512" />
        </article>
      </div>
    </section>

    <section class="asset-section" aria-labelledby="colors-heading">
      <div class="section-copy">
        <p class="eyebrow">Colors</p>
        <h2 id="colors-heading">Core palette.</h2>
      </div>
      <div class="color-grid">
        {colors.map((color) => (
          <article class="color-card">
            <span class="swatch" style={`--swatch: ${color.value}`}></span>
            <div>
              <h3>{color.name}</h3>
              <p>{color.value}</p>
              <code>{color.token}</code>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .brand-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: 72px 0 94px;
  }

  .brand-hero {
    max-width: 820px;
    margin-bottom: 64px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--green-dark);
    font-size: 0.74rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    max-width: 820px;
    font-size: clamp(3.1rem, 7vw, 6rem);
    font-weight: 690;
    letter-spacing: 0;
    line-height: 0.96;
  }

  h2 {
    font-size: clamp(2rem, 3.6vw, 3.6rem);
    font-weight: 660;
    letter-spacing: 0;
    line-height: 1.02;
  }

  .brand-hero p,
  .section-copy p:not(.eyebrow) {
    max-width: 640px;
    margin-top: 22px;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.58;
  }

  .asset-section {
    display: grid;
    grid-template-columns: minmax(0, 0.55fr) minmax(0, 1fr);
    gap: clamp(32px, 6vw, 72px);
    align-items: start;
    padding: 72px 0;
    border-top: 1px solid var(--line);
  }

  .asset-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(180px, 0.62fr);
    gap: 14px;
  }

  .asset-card,
  .color-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(237, 242, 237, 0.48)),
      var(--soft);
    box-shadow: var(--card-shadow);
  }

  .asset-card {
    min-height: 220px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 22px;
  }

  .asset-card span {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 720;
  }

  .asset-card img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .logo-card img {
    width: min(360px, 100%);
  }

  .icon-card {
    align-items: flex-start;
  }

  .icon-card img {
    width: 84px;
  }

  .color-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .color-card {
    min-height: 132px;
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 16px;
    align-items: center;
    padding: 18px;
  }

  .swatch {
    width: 56px;
    height: 56px;
    border: 1px solid rgba(20, 24, 22, 0.08);
    border-radius: 8px;
    background: var(--swatch);
  }

  .color-card h3 {
    margin-bottom: 4px;
    font-size: 1rem;
  }

  .color-card p,
  .color-card code {
    display: block;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .color-card code {
    margin-top: 6px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  }

  @media (max-width: 900px) {
    .asset-section,
    .asset-grid,
    .color-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .brand-shell {
      width: min(100% - 28px, 520px);
      padding: 48px 0 64px;
    }

    h1 {
      font-size: 3rem;
    }

    h2 {
      font-size: 2.12rem;
    }

    .asset-section {
      padding: 52px 0;
    }
  }
</style>
