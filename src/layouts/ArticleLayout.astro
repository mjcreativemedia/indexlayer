---
import type { PostEntry } from "../lib/content";
import { formatDate, getEntryPath, postIndexMeta } from "../lib/content";
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

export interface Props {
  entry: PostEntry;
  related: PostEntry[];
}

const { entry, related } = Astro.props;
const canonicalPath = getEntryPath(entry);
const site = Astro.site ?? new URL("https://indexlayer.pro");
const canonicalUrl = new URL(canonicalPath, site).href;
const title = `${entry.data.title} | IndexLayer`;
const heroImage = entry.data.heroImage ?? "/images/brand/indexlayer-og.png";
const showHeroImage =
  entry.data.slug !== "chicago-fight-team-homepage-rebuild" && !entry.data.hideHeroImage;
const authorName = entry.data.authorName;
const authorImage = entry.data.authorImage;
const authorImageUrl = new URL(authorImage, site).href;
const workSummaryItems = [
  ["Client", entry.data.client],
  ["Project", entry.data.projectType],
  ["Problem", entry.data.problem],
  ["Outcome", entry.data.outcome],
].filter((item): item is [string, string] => Boolean(item[1]));

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  image: new URL(heroImage, site).href,
  author: {
    "@type": "Person",
    name: authorName,
    image: authorImageUrl,
    url: new URL("/", site).href,
  },
  publisher: {
    "@type": "Organization",
    name: "IndexLayer",
    url: new URL("/", site).href,
    logo: {
      "@type": "ImageObject",
      url: new URL("/images/brand/indexlayer-logo.png", site).href,
    },
  },
};

const breadcrumbsJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: new URL("/", site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: postIndexMeta.label,
      item: new URL(postIndexMeta.path, site).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: entry.data.title,
      item: canonicalUrl,
    },
  ],
};
---

<BaseLayout
  title={title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  ogImage={heroImage}
  ogType="article"
  jsonLd={[articleJsonLd, breadcrumbsJsonLd]}
>
  <SiteHeader />

  <main class="article-shell">
    <article>
      <header class="article-hero">
        <p class="eyebrow">{entry.data.category}</p>
        <h1>{entry.data.title}</h1>
        <p class="description">{entry.data.description}</p>
        <div class="meta-row">
          <span>{formatDate(entry.data.pubDate)}</span>
          <span class="author-meta">
            <img src={authorImage} alt="" width="24" height="24" />
            <strong>{authorName}</strong>
          </span>
        </div>
        {showHeroImage && (
          <figure class="featured-image">
            <img src={heroImage} alt="" width="1200" height="630" />
          </figure>
        )}
        <div class="tag-row">
          {entry.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </header>

      {workSummaryItems.length > 0 && (
        <aside class="case-summary" aria-label="Work summary">
          {workSummaryItems.map(([label, value]) => (
            <div>
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
          ))}
        </aside>
      )}

      <div class="article-body">
        <slot />
      </div>
    </article>

    {related.length > 0 && (
      <section class="related" aria-labelledby="related-heading">
        <h2 id="related-heading">Related reading</h2>
        <div class="related-grid">
          {related.map((item) => (
            <a href={getEntryPath(item)}>
              <span>{item.data.category}</span>
              <strong>{item.data.title}</strong>
              <p>{item.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .article-shell {
    width: min(980px, calc(100% - 40px));
    margin: 0 auto;
    padding: 72px 0 94px;
  }

  .article-hero {
    padding-bottom: 38px;
    border-bottom: 1px solid var(--line);
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--green-dark);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 760;
    line-height: 1.45;
  }

  h1 {
    margin: 0 0 24px;
    max-width: 900px;
    font-size: clamp(2.9rem, 6.2vw, 5.9rem);
    line-height: 0.98;
    letter-spacing: 0;
    font-weight: 690;
  }

  .description {
    max-width: 720px;
    margin: 0 0 18px;
    color: var(--muted);
    font-size: 1.24rem;
    line-height: 1.62;
  }

  .featured-image {
    margin: 0 0 24px;
  }

  .featured-image img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: var(--soft);
    box-shadow: var(--card-shadow);
    object-fit: cover;
  }

  .meta-row,
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .meta-row {
    align-items: center;
    margin: 0 0 24px;
    color: var(--muted);
    font-size: 0.94rem;
    gap: 0;
  }

  .meta-row > span:not(:last-child)::after {
    content: "\2022";
    margin: 0 10px;
    color: var(--muted);
  }

  .author-meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .author-meta img {
    display: block;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--line);
  }

  .author-meta strong {
    color: var(--ink);
    font-weight: 650;
  }

  .tag-row {
    margin-top: 16px;
  }

  .tag-row span {
    border: 1px solid var(--line);
    background: transparent;
    border-radius: var(--radius-chip);
    padding: 4px 8px;
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.2;
  }

  .case-summary {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    margin: 34px 0 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: var(--line);
    box-shadow: var(--card-shadow);
    overflow: hidden;
  }

  .case-summary div {
    background: var(--card-bg);
    padding: 18px;
  }

  .case-summary span {
    display: block;
    margin-bottom: 8px;
    color: var(--muted);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .case-summary strong {
    display: block;
    line-height: 1.35;
  }

  .article-body {
    padding-top: 38px;
    color: var(--ink);
    font-size: 1.08rem;
    line-height: 1.76;
  }

  .article-body :global(h2) {
    margin: 54px 0 18px;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    line-height: 1.08;
  }

  .article-body :global(h3) {
    margin: 36px 0 14px;
    font-size: 1.34rem;
  }

  .article-body :global(p),
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 22px;
  }

  .article-body :global(a) {
    color: var(--green-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-body :global(code) {
    border: 1px solid var(--line);
    background: var(--soft);
    padding: 2px 5px;
    font-size: 0.92em;
  }

  .article-body :global(pre code) {
    border: 0;
    background: transparent;
    padding: 0;
  }

  .related {
    margin-top: 72px;
    padding-top: 42px;
    border-top: 1px solid var(--line);
  }

  .related h2 {
    margin: 0 0 20px;
    font-size: 1.4rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .related-grid a {
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    padding: 18px;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .related-grid a:hover {
    border-color: var(--green);
    color: var(--green-dark);
    transform: translateY(-2px);
  }

  .related-grid span {
    display: block;
    margin-bottom: 10px;
    color: var(--green-dark);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 760;
  }

  .related-grid strong {
    display: block;
    margin-bottom: 10px;
    line-height: 1.26;
  }

  .related-grid p {
    margin: 0;
    color: var(--muted);
    font-size: 0.94rem;
  }

  @media (max-width: 760px) {
    .article-shell {
      width: min(100% - 28px, 900px);
      padding-top: 42px;
    }

    h1 {
      font-size: 2.72rem;
    }

    .case-summary,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
