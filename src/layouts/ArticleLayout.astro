---
import type { PostEntry } from "../lib/content";
import { formatDate, getEntryPath, postIndexMeta } from "../lib/content";
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

export interface Props {
  entry: PostEntry;
  related: PostEntry[];
}

const { entry, related } = Astro.props;
const canonicalPath = getEntryPath(entry);
const site = Astro.site ?? new URL("https://indexlayer.pro");
const canonicalUrl = new URL(canonicalPath, site).href;
const title = `${entry.data.title} | IndexLayer`;
const heroImage = entry.data.heroImage;
const authorName = entry.data.authorName;
const authorImage = entry.data.authorImage;
const authorImageUrl = new URL(authorImage, site).href;
const workSummaryItems = [
  ["Client", entry.data.client],
  ["Project", entry.data.projectType],
  ["Problem", entry.data.problem],
  ["Outcome", entry.data.outcome],
].filter((item): item is [string, string] => Boolean(item[1]));

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  image: heroImage ? new URL(heroImage, site).href : new URL("/images/brand/indexlayer-og.png", site).href,
  author: {
    "@type": "Person",
    name: authorName,
    image: authorImageUrl,
    url: new URL("/", site).href,
  },
  publisher: {
    "@type": "Organization",
    name: "IndexLayer",
    url: new URL("/", site).href,
    logo: {
      "@type": "ImageObject",
      url: new URL("/images/brand/indexlayer-mark.png", site).href,
    },
  },
};

const breadcrumbsJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: new URL("/", site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: postIndexMeta.label,
      item: new URL(postIndexMeta.path, site).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: entry.data.title,
      item: canonicalUrl,
    },
  ],
};
---

<BaseLayout
  title={title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  ogImage={heroImage}
  ogType="article"
  jsonLd={[articleJsonLd, breadcrumbsJsonLd]}
>
  <SiteHeader />

  <main class="article-shell">
    <a class="back-link" href={postIndexMeta.path}>{postIndexMeta.label}</a>
    <article>
      <header class="article-hero">
        <p class="eyebrow">{entry.data.category}</p>
        <h1>{entry.data.title}</h1>
        <p class="description">{entry.data.description}</p>
        <div class="author-row">
          <img src={authorImage} alt="" width="44" height="44" />
          <div>
            <span>Written by</span>
            <strong>{authorName}</strong>
          </div>
        </div>
        <div class="meta-row">
          <span>{formatDate(entry.data.pubDate)}</span>
          {entry.data.updatedDate && <span>Updated {formatDate(entry.data.updatedDate)}</span>}
          {entry.data.pillar && <span>{entry.data.pillar}</span>}
        </div>
        <div class="tag-row">
          {entry.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </header>

      {workSummaryItems.length > 0 && (
        <aside class="case-summary" aria-label="Work summary">
          {workSummaryItems.map(([label, value]) => (
            <div>
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
          ))}
        </aside>
      )}

      <div class="article-body">
        <slot />
      </div>
    </article>

    {related.length > 0 && (
      <section class="related" aria-labelledby="related-heading">
        <h2 id="related-heading">Related reading</h2>
        <div class="related-grid">
          {related.map((item) => (
            <a href={getEntryPath(item)}>
              <span>{item.data.category}</span>
              <strong>{item.data.title}</strong>
              <p>{item.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .article-shell {
    width: min(900px, calc(100% - 40px));
    margin: 0 auto;
    padding: 58px 0 86px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 44px;
    color: var(--green-dark);
    font-weight: 650;
  }

  .article-hero {
    padding-bottom: 36px;
    border-bottom: 1px solid var(--line);
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--green-dark);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
  }

  h1 {
    margin: 0 0 24px;
    font-size: clamp(2.6rem, 6vw, 5.1rem);
    line-height: 1;
    letter-spacing: 0;
    font-weight: 680;
  }

  .description {
    max-width: 760px;
    margin: 0 0 24px;
    color: var(--muted);
    font-size: 1.24rem;
    line-height: 1.62;
  }

  .author-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 22px;
  }

  .author-row img {
    width: 44px;
    height: 44px;
    border: 1px solid var(--line);
    border-radius: 999px;
    object-fit: cover;
  }

  .author-row span,
  .author-row strong {
    display: block;
  }

  .author-row span {
    color: var(--muted);
    font-size: 0.84rem;
  }

  .author-row strong {
    color: var(--ink);
    line-height: 1.2;
  }

  .meta-row,
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .meta-row {
    color: var(--muted);
    font-size: 0.94rem;
  }

  .meta-row span:not(:last-child)::after {
    content: "/";
    margin-left: 10px;
    color: var(--line);
  }

  .tag-row {
    margin-top: 18px;
  }

  .tag-row span {
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 6px 10px;
    color: var(--green-dark);
    font-size: 0.86rem;
  }

  .case-summary {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    margin: 34px 0 0;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .case-summary div {
    background: var(--paper);
    padding: 18px;
  }

  .case-summary span {
    display: block;
    margin-bottom: 8px;
    color: var(--muted);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .case-summary strong {
    display: block;
    line-height: 1.35;
  }

  .article-body {
    padding-top: 38px;
    color: var(--ink);
    font-size: 1.08rem;
    line-height: 1.76;
  }

  .article-body :global(h2) {
    margin: 54px 0 18px;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    line-height: 1.08;
  }

  .article-body :global(h3) {
    margin: 36px 0 14px;
    font-size: 1.34rem;
  }

  .article-body :global(p),
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 22px;
  }

  .article-body :global(a) {
    color: var(--green-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-body :global(code) {
    border: 1px solid var(--line);
    background: var(--soft);
    padding: 2px 5px;
    font-size: 0.92em;
  }

  .article-body :global(pre code) {
    border: 0;
    background: transparent;
    padding: 0;
  }

  .related {
    margin-top: 72px;
    padding-top: 42px;
    border-top: 1px solid var(--line);
  }

  .related h2 {
    margin: 0 0 20px;
    font-size: 1.4rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .related-grid a {
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 18px;
  }

  .related-grid span {
    display: block;
    margin-bottom: 10px;
    color: var(--green-dark);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .related-grid strong {
    display: block;
    margin-bottom: 10px;
    line-height: 1.26;
  }

  .related-grid p {
    margin: 0;
    color: var(--muted);
    font-size: 0.94rem;
  }

  @media (max-width: 760px) {
    .article-shell {
      width: min(100% - 28px, 900px);
      padding-top: 42px;
    }

    .case-summary,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
