---
export interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  robots?: string;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogImage = "/images/brand/indexlayer-og.png",
  ogType = "website",
  jsonLd,
  robots,
} = Astro.props;

const site = Astro.site ?? new URL("https://indexlayer.pro");
const canonicalUrl = new URL(canonicalPath, site);
canonicalUrl.search = "";
canonicalUrl.hash = "";

const ogImageUrl = new URL(ogImage, site);
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:site_name" content="IndexLayer" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />

    {jsonLdItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <slot />
    <dialog class="coming-soon-modal" aria-labelledby="coming-soon-title">
      <div class="coming-soon-card">
        <button class="coming-soon-close" type="button" aria-label="Close coming soon modal">
          ×
        </button>
        <img
          class="coming-soon-logo"
          src="/images/brand/indexlayer-logo.png"
          alt="IndexLayer"
          width="136"
          height="33"
        />
        <p class="coming-soon-kicker">Coming soon</p>
        <h2 id="coming-soon-title">This is almost ready.</h2>
        <p>
          The IndexLayer portal and audit intake are being prepared. For now, the site is focused
          on the public architecture, proof, and launch content.
        </p>
      </div>
    </dialog>
    <script>
      const modal = document.querySelector(".coming-soon-modal");
      const modalCard = modal?.querySelector(".coming-soon-card");
      const closeButton = modal?.querySelector(".coming-soon-close");
      const triggers = document.querySelectorAll("[data-coming-soon-trigger]");

      const openModal = () => {
        if (!(modal instanceof HTMLDialogElement)) return;
        if (!modal.open) modal.showModal();
      };

      const closeModal = () => {
        if (!(modal instanceof HTMLDialogElement)) return;
        modal.close();
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", (event) => {
          event.preventDefault();
          openModal();
        });
      });

      closeButton?.addEventListener("click", closeModal);
      modal?.addEventListener("click", (event) => {
        if (event.target === modal || !modalCard?.contains(event.target)) {
          closeModal();
        }
      });

      const header = document.querySelector(".site-header");
      const navToggle = document.querySelector(".nav-toggle");
      const submenuToggles = document.querySelectorAll(".nav-submenu-toggle");

      navToggle?.addEventListener("click", () => {
        const isOpen = header?.classList.toggle("is-nav-open") ?? false;
        navToggle.setAttribute("aria-expanded", String(isOpen));
        navToggle.setAttribute(
          "aria-label",
          isOpen ? "Close navigation menu" : "Open navigation menu",
        );
      });

      submenuToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          const group = toggle.closest(".nav-group");
          const isOpen = group?.classList.toggle("is-submenu-open") ?? false;
          toggle.setAttribute("aria-expanded", String(isOpen));
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f8f5;
    --paper: #ffffff;
    --ink: #141816;
    --muted: #5f6862;
    --line: #dfe5de;
    --soft: #edf2ed;
    --green: #2c6f4a;
    --green-dark: #174d34;
    --green-soft: #d9eadf;
    --shadow: 0 24px 80px rgba(20, 24, 22, 0.08);
    --card-bg: rgba(255, 255, 255, 0.78);
    --card-shadow: 0 18px 54px rgba(20, 24, 22, 0.055);
    --radius-card: 8px;
    --radius-control: 6px;
    --radius-chip: 5px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--ink);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    line-height: 1.5;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header,
  .site-footer {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .site-header {
    min-height: 78px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
  }

  .brand,
  .site-nav,
  .nav-main,
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .brand {
    font-weight: 650;
    letter-spacing: 0;
  }

  .brand-mark {
    width: 116px;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .site-nav {
    gap: 30px;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .nav-toggle,
  .nav-submenu-toggle {
    display: none;
  }

  .nav-main {
    gap: 24px;
  }

  .nav-actions {
    gap: 16px;
    margin-left: 4px;
    padding-left: 28px;
    border-left: 1px solid var(--line);
  }

  .site-nav a:hover,
  .nav-group:focus-within > a,
  .nav-group:hover > a {
    color: var(--green-dark);
  }

  .nav-group {
    position: relative;
    min-height: 78px;
    display: flex;
    align-items: center;
  }

  .nav-menu {
    position: absolute;
    top: calc(100% - 10px);
    left: 50%;
    z-index: 20;
    min-width: 220px;
    display: grid;
    gap: 4px;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: var(--shadow);
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 8px);
    transition:
      opacity 140ms ease,
      transform 140ms ease;
  }

  .nav-menu a {
    border-radius: 6px;
    padding: 9px 10px;
    color: var(--muted);
    white-space: nowrap;
  }

  .nav-menu a:hover {
    background: var(--soft);
  }

  .nav-group:focus-within .nav-menu,
  .nav-group:hover .nav-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }

  .nav-secondary {
    color: var(--green-dark);
    font-weight: 650;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    border: 1px solid var(--ink);
    border-radius: 6px;
    background: var(--ink);
    padding: 0 14px;
    color: white;
    font-weight: 680;
  }

  .nav-cta:hover {
    background: var(--green-dark);
    border-color: var(--green-dark);
    color: white;
  }

  .site-footer {
    display: grid;
    grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.2fr);
    align-items: start;
    justify-content: space-between;
    gap: 40px;
    border-top: 1px solid var(--line);
    padding: 38px 0 44px;
    color: var(--muted);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 24px;
  }

  .footer-columns div {
    display: grid;
    gap: 9px;
  }

  .footer-columns span {
    color: var(--ink);
    font-weight: 700;
  }

  .site-footer a:hover {
    color: var(--green-dark);
  }

  .coming-soon-modal {
    width: min(100% - 32px, 460px);
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: var(--shadow);
    padding: 0;
    color: var(--ink);
  }

  .coming-soon-modal::backdrop {
    background: rgba(20, 24, 22, 0.36);
    backdrop-filter: blur(8px);
  }

  .coming-soon-card {
    position: relative;
    display: grid;
    justify-items: center;
    padding: 34px 30px 32px;
    text-align: center;
  }

  .coming-soon-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    font-size: 1.35rem;
    line-height: 1;
  }

  .coming-soon-close:hover {
    border-color: var(--green);
    color: var(--green-dark);
  }

  .coming-soon-logo {
    width: 136px;
    height: auto;
    margin-bottom: 28px;
  }

  .coming-soon-kicker {
    margin: 0 0 10px;
    color: var(--green-dark);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .coming-soon-card h2 {
    margin: 0;
    font-size: clamp(1.55rem, 4vw, 2.08rem);
    line-height: 1.08;
  }

  .coming-soon-card p:not(.coming-soon-kicker) {
    max-width: 34ch;
    margin: 16px 0 0;
    color: var(--muted);
    line-height: 1.58;
  }

  @media (max-width: 640px) {
    .site-header,
    .site-footer {
      width: min(100% - 28px, 520px);
    }

    .site-header {
      position: relative;
      align-items: center;
      justify-content: space-between;
      min-height: 72px;
      padding: 14px 0;
    }

    .site-nav {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      right: 0;
      z-index: 30;
      display: none;
      gap: 0;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.98);
      box-shadow: var(--shadow);
      padding: 10px;
      color: var(--ink);
      font-size: 0.94rem;
    }

    .site-header.is-nav-open .site-nav {
      display: grid;
    }

    .nav-toggle {
      width: 42px;
      height: 42px;
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.68);
      color: var(--ink);
      cursor: pointer;
    }

    .nav-toggle span {
      width: 17px;
      height: 2px;
      border-radius: 999px;
      background: currentColor;
      transition:
        transform 160ms ease,
        opacity 160ms ease;
    }

    .site-header.is-nav-open .nav-toggle span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .site-header.is-nav-open .nav-toggle span:nth-child(2) {
      opacity: 0;
    }

    .site-header.is-nav-open .nav-toggle span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .nav-main,
    .nav-actions {
      display: grid;
      align-items: stretch;
      gap: 4px;
    }

    .nav-main > a,
    .nav-submenu-toggle,
    .nav-actions a {
      width: 100%;
      min-height: 42px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-radius: 6px;
      padding: 0 12px;
      font: inherit;
      font-weight: 650;
      text-align: left;
    }

    .nav-main > a:hover,
    .nav-submenu-toggle:hover,
    .nav-actions a:hover {
      background: var(--soft);
      color: var(--green-dark);
    }

    .nav-parent {
      display: none;
    }

    .nav-submenu-toggle {
      border: 0;
      background: transparent;
      color: var(--ink);
      cursor: pointer;
    }

    .nav-submenu-toggle::after {
      content: "+";
      color: var(--green-dark);
      font-size: 1.08rem;
      font-weight: 760;
    }

    .nav-submenu-toggle[aria-expanded="true"]::after {
      content: "−";
    }

    .nav-group {
      min-height: 0;
      display: grid;
    }

    .nav-menu {
      position: static;
      min-width: 0;
      display: none;
      gap: 2px;
      margin: 0 0 6px;
      padding: 0 0 0 12px;
      border: 0;
      border-left: 1px solid var(--line);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      opacity: 1;
      pointer-events: auto;
      transform: none;
    }

    .nav-group.is-submenu-open .nav-menu {
      display: grid;
    }

    .nav-menu a {
      min-height: 36px;
      display: flex;
      align-items: center;
      border-radius: 6px;
      padding: 0 10px;
      white-space: normal;
    }

    .nav-actions {
      width: 100%;
      margin-left: 0;
      padding-left: 0;
      border-left: 0;
      margin-top: 8px;
      padding-top: 10px;
      border-top: 1px solid var(--line);
    }

    .brand-mark {
      width: 111px;
    }

    .site-footer {
      align-items: flex-start;
      grid-template-columns: 1fr;
      justify-content: center;
    }

    .footer-columns {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 500px) {
    .site-header,
    .site-footer {
      width: min(100% - 28px, 362px);
    }

    .nav-cta {
      width: 100%;
      justify-content: center;
      min-height: 44px;
    }
  }
</style>
