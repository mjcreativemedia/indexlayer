---
export interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  robots?: string;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogImage = "/images/brand/indexlayer-og.png",
  ogType = "website",
  jsonLd,
  robots,
} = Astro.props;

const site = Astro.site ?? new URL("https://indexlayer.pro");
const canonicalUrl = new URL(canonicalPath, site);
canonicalUrl.search = "";
canonicalUrl.hash = "";

const ogImageUrl = new URL(ogImage, site);
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:site_name" content="IndexLayer" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />

    {jsonLdItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f8f5;
    --paper: #ffffff;
    --ink: #141816;
    --muted: #5f6862;
    --line: #dfe5de;
    --soft: #edf2ed;
    --green: #2c6f4a;
    --green-dark: #174d34;
    --green-soft: #d9eadf;
    --shadow: 0 24px 80px rgba(20, 24, 22, 0.08);
    --card-bg: rgba(255, 255, 255, 0.78);
    --card-shadow: 0 18px 54px rgba(20, 24, 22, 0.055);
    --radius-card: 8px;
    --radius-control: 6px;
    --radius-chip: 5px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--ink);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    line-height: 1.5;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header,
  .site-footer {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .site-header {
    min-height: 78px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
  }

  .brand,
  .site-nav,
  .nav-main,
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .brand {
    font-weight: 650;
    letter-spacing: 0;
  }

  .brand-mark {
    width: 154px;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .site-nav {
    gap: 30px;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .nav-main {
    gap: 24px;
  }

  .nav-actions {
    gap: 16px;
    margin-left: 4px;
    padding-left: 28px;
    border-left: 1px solid var(--line);
  }

  .site-nav a:hover,
  .nav-group:focus-within > a,
  .nav-group:hover > a {
    color: var(--green-dark);
  }

  .nav-group {
    position: relative;
    min-height: 78px;
    display: flex;
    align-items: center;
  }

  .nav-menu {
    position: absolute;
    top: calc(100% - 10px);
    left: 50%;
    z-index: 20;
    min-width: 220px;
    display: grid;
    gap: 4px;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: var(--shadow);
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 8px);
    transition:
      opacity 140ms ease,
      transform 140ms ease;
  }

  .nav-menu a {
    border-radius: 6px;
    padding: 9px 10px;
    color: var(--muted);
    white-space: nowrap;
  }

  .nav-menu a:hover {
    background: var(--soft);
  }

  .nav-group:focus-within .nav-menu,
  .nav-group:hover .nav-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }

  .nav-secondary {
    color: var(--green-dark);
    font-weight: 650;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    border: 1px solid var(--ink);
    border-radius: 6px;
    background: var(--ink);
    padding: 0 14px;
    color: white;
    font-weight: 680;
  }

  .nav-cta:hover {
    background: var(--green-dark);
    border-color: var(--green-dark);
    color: white;
  }

  .site-footer {
    display: grid;
    grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.2fr);
    align-items: start;
    justify-content: space-between;
    gap: 40px;
    border-top: 1px solid var(--line);
    padding: 38px 0 44px;
    color: var(--muted);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 24px;
  }

  .footer-columns div {
    display: grid;
    gap: 9px;
  }

  .footer-columns span {
    color: var(--ink);
    font-weight: 700;
  }

  .site-footer a:hover {
    color: var(--green-dark);
  }

  @media (max-width: 640px) {
    .site-header,
    .site-footer {
      width: min(100% - 28px, 520px);
    }

    .site-header {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      gap: 16px;
      padding: 18px 0 20px;
    }

    .site-nav {
      width: 100%;
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: 10px 16px;
      font-size: 0.88rem;
    }

    .nav-main,
    .nav-actions {
      flex-wrap: wrap;
    }

    .nav-actions {
      width: 100%;
      margin-left: 0;
      padding-left: 0;
      border-left: 0;
      padding-top: 8px;
      border-top: 1px solid var(--line);
    }

    .brand-mark {
      width: 148px;
    }

    .nav-group {
      min-height: auto;
    }

    .nav-menu {
      display: none;
    }

    .site-footer {
      align-items: flex-start;
      grid-template-columns: 1fr;
      justify-content: center;
    }

    .footer-columns {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 500px) {
    .site-header,
    .site-footer {
      width: min(100% - 28px, 362px);
    }

    .site-nav {
      display: grid;
      grid-template-columns: 1fr;
      align-items: center;
      row-gap: 12px;
    }

    .nav-main {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, max-content));
      align-items: center;
      row-gap: 12px;
    }

    .nav-actions {
      display: grid;
      grid-template-columns: minmax(0, max-content) minmax(0, 1fr);
      align-items: center;
      gap: 12px;
    }

    .site-nav > a:not(.nav-cta),
    .nav-group > a {
      min-height: 34px;
      display: inline-flex;
      align-items: center;
    }

    .nav-cta {
      width: 100%;
      justify-content: center;
      min-height: 44px;
    }
  }
</style>
