---
import type { PostEntry } from "../lib/content";
import { formatDate, getEntryPath } from "../lib/content";
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

export interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  entries: PostEntry[];
  eyebrow?: string;
}

const { title, description, canonicalPath, entries, eyebrow = "IndexLayer posts" } = Astro.props;
const pageTitle = `${title} | IndexLayer`;
---

<BaseLayout title={pageTitle} description={description} canonicalPath={canonicalPath}>
  <SiteHeader />

  <main class="listing-shell">
    <section class="listing-hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{description}</p>
    </section>

    <section class="entry-grid" aria-label={title}>
      {entries.map((entry) => (
        <a class="entry-card" href={getEntryPath(entry)}>
          <span>{entry.data.category}</span>
          <h2>{entry.data.title}</h2>
          <p>{entry.data.description}</p>
          <div>
            <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
            {entry.data.pillar && <strong>{entry.data.pillar}</strong>}
          </div>
        </a>
      ))}
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .listing-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: 68px 0 92px;
  }

  .listing-hero {
    max-width: 840px;
    margin-bottom: 52px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--green-dark);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
  }

  h1 {
    margin: 0 0 24px;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1;
  }

  .listing-hero p {
    margin: 0;
    color: var(--muted);
    font-size: 1.24rem;
    line-height: 1.62;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .entry-card {
    min-height: 330px;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 24px;
    transition:
      border-color 160ms ease,
      transform 160ms ease;
  }

  .entry-card:hover {
    border-color: var(--green);
    transform: translateY(-2px);
  }

  .entry-card span {
    margin-bottom: 20px;
    color: var(--green-dark);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .entry-card h2 {
    margin: 0 0 14px;
    font-size: 1.55rem;
    line-height: 1.08;
  }

  .entry-card p {
    margin: 0 0 24px;
    color: var(--muted);
    line-height: 1.58;
  }

  .entry-card div {
    display: grid;
    gap: 6px;
    margin-top: auto;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .entry-card strong {
    color: var(--ink);
  }

  @media (max-width: 940px) {
    .entry-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .listing-shell {
      width: min(100% - 28px, 1180px);
      padding: 48px 0;
    }

    .entry-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
