---
import type { PostEntry } from "../lib/content";
import { categoryMeta, formatDate, getEntryPath, type PostCategory } from "../lib/content";
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

export interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  entries: PostEntry[];
  eyebrow?: string;
  showCategoryFilters?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  entries,
  eyebrow = "IndexLayer posts",
  showCategoryFilters = false,
} = Astro.props;
const pageTitle = `${title} | IndexLayer`;
const categoryCounts = entries.reduce(
  (counts, entry) => counts.set(entry.data.category, (counts.get(entry.data.category) ?? 0) + 1),
  new Map<PostCategory, number>(),
);
const categories = Object.values(categoryMeta).filter((meta) => categoryCounts.has(meta.label));
---

<BaseLayout title={pageTitle} description={description} canonicalPath={canonicalPath}>
  <SiteHeader />

  <main class="listing-shell">
    <section class="listing-hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{description}</p>
    </section>

    {showCategoryFilters && categories.length > 0 && (
      <section class="category-filter" aria-label="Filter posts by category">
        <button type="button" class="active" data-filter="all">
          All <span>{entries.length}</span>
        </button>
        {categories.map((category) => (
          <button type="button" data-filter={category.label}>
            {category.label} <span>{categoryCounts.get(category.label)}</span>
          </button>
        ))}
      </section>
    )}

    <section class="entry-grid" aria-label={title}>
      {entries.map((entry) => (
        <a class="entry-card" href={getEntryPath(entry)} data-category={entry.data.category}>
          <span>{entry.data.category}</span>
          <h2>{entry.data.title}</h2>
          <p>{entry.data.preview ?? entry.data.description}</p>
          <div>
            <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
            <div class="author-line">
              <img src={entry.data.authorImage ?? "/images/authors/mitch-argamasilla.jpeg"} alt="" width="28" height="28" />
              <strong>{entry.data.authorName}</strong>
            </div>
          </div>
        </a>
      ))}
    </section>
  </main>

  <SiteFooter />

  {showCategoryFilters && (
    <script>
      const filterButtons = Array.from(document.querySelectorAll("[data-filter]"));
      const postCards = Array.from(document.querySelectorAll("[data-category]"));

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const filter = button.getAttribute("data-filter");

          filterButtons.forEach((item) => item.classList.toggle("active", item === button));
          postCards.forEach((card) => {
            const shouldShow = filter === "all" || card.getAttribute("data-category") === filter;
            card.toggleAttribute("hidden", !shouldShow);
          });
        });
      });
    </script>
  )}
</BaseLayout>

<style>
  .listing-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: 72px 0 94px;
  }

  .listing-hero {
    max-width: 860px;
    margin-bottom: 54px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--green-dark);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 760;
    line-height: 1.45;
  }

  h1 {
    margin: 0 0 24px;
    font-size: clamp(3.2rem, 7vw, 6.2rem);
    line-height: 0.96;
    letter-spacing: 0;
    font-weight: 690;
  }

  .listing-hero p {
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.7vw, 1.24rem);
    line-height: 1.62;
  }

  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: -22px 0 34px;
  }

  .category-filter button {
    min-height: 38px;
    border: 1px solid var(--line);
    border-radius: var(--radius-control);
    background: rgba(255, 255, 255, 0.56);
    color: var(--muted);
    padding: 0 13px;
    font: inherit;
    font-size: 0.92rem;
    font-weight: 680;
    cursor: pointer;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .category-filter button:hover,
  .category-filter button.active {
    border-color: var(--green-dark);
    background: var(--ink);
    color: white;
  }

  .category-filter span {
    margin-left: 6px;
    opacity: 0.68;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .entry-card {
    min-height: 330px;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    padding: 26px;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .entry-card:hover {
    border-color: var(--green);
    color: var(--green-dark);
    transform: translateY(-2px);
  }

  .entry-card[hidden] {
    display: none;
  }

  .entry-card span {
    margin-bottom: 20px;
    color: var(--green-dark);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 760;
  }

  .entry-card h2 {
    margin: 0 0 14px;
    font-size: 1.55rem;
    line-height: 1.08;
  }

  .entry-card p {
    margin: 0 0 24px;
    color: var(--muted);
    line-height: 1.58;
  }

  .entry-card div {
    display: grid;
    gap: 6px;
    margin-top: auto;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .entry-card strong {
    color: var(--ink);
  }

  .author-line {
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    align-items: center;
    gap: 10px;
  }

  .author-line img {
    display: block;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--line);
  }

  .author-line strong {
    display: block;
    min-width: 0;
    line-height: 1.15;
  }

  @media (max-width: 940px) {
    .entry-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .listing-shell {
      width: min(100% - 28px, 1180px);
      padding: 48px 0;
    }

    h1 {
      font-size: 3rem;
    }

    .entry-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
