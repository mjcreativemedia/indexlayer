---
export interface Props {
  src?: string;
  alt?: string;
  caption: string;
}

const { src, alt = "", caption } = Astro.props;
---

<figure class="screenshot-figure">
  {src ? <img src={src} alt={alt} loading="lazy" /> : <div class="placeholder" aria-hidden="true"></div>}
  <figcaption>{caption}</figcaption>
</figure>

<style>
  .screenshot-figure {
    margin: 32px 0;
  }

  img,
  .placeholder {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    background: linear-gradient(135deg, var(--paper), var(--soft));
    box-shadow: var(--card-shadow);
  }

  .placeholder {
    min-height: 260px;
  }

  figcaption {
    margin-top: 10px;
    color: var(--muted);
    font-size: 0.92rem;
  }
</style>
