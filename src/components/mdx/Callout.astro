---
export interface Props {
  title?: string;
}

const { title = "IndexLayer Lesson" } = Astro.props;
---

<aside class="callout">
  <strong>{title}</strong>
  <slot />
</aside>

<style>
  .callout {
    margin: 30px 0;
    border: 1px solid var(--line);
    border-left: 3px solid var(--green);
    border-radius: var(--radius-card);
    background: rgba(217, 234, 223, 0.54);
    box-shadow: var(--card-shadow);
    padding: 18px 20px;
  }

  .callout strong {
    display: block;
    margin-bottom: 8px;
    color: var(--green-dark);
  }

  .callout :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
