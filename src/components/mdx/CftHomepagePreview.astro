---
export interface Props {
  mode?: "article" | "standalone";
}

const imageBase = "/images/work/chicago-fight-team";
const { mode = "article" } = Astro.props;
---

<section class:list={["cft-preview", mode === "standalone" && "is-standalone"]} aria-label="Chicago Fight Team homepage rebuild preview">
  <header class="preview-frame">
    <nav class="preview-nav" aria-label="Preview navigation">
      <a class="brand" href="https://chicagofightteam.org/">
        <img src={`${imageBase}/cft-logo.jpeg`} alt="" loading="lazy" />
      </a>
      <div class="nav-links" aria-hidden="true">
        <span>Programs</span>
        <span>Coaches</span>
        <span>Schedule</span>
      </div>
      <details class="mobile-menu">
        <summary aria-label="Open navigation menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div>
          <a href="#programs">Programs</a>
          <a href="#coaches">Coaches</a>
          <a href="https://chicagofightteam.org/">Schedule</a>
          <a href="https://chicagofightteam.org/">Start Training</a>
        </div>
      </details>
      <a class="nav-cta" href="https://chicagofightteam.org/">Start</a>
    </nav>

    <div class="hero-grid">
      <div class="hero-copy">
        <p class="kicker">MMA • BJJ • Muay Thai</p>
        <h2>Chicago Fight Team</h2>
        <p>
          Home of world champions with more than 20 years of fight training and
          competition prep.
        </p>
        <div class="hero-actions">
          <a href="tel:+17738855700">Call</a>
          <a href="https://www.google.com/maps/place/Chicago+Fight+Team/">Visit Gym</a>
        </div>
      </div>
      <figure class="hero-media">
        <img src={`${imageBase}/training-room-wide.jpeg`} alt="Chicago Fight Team training room" loading="lazy" />
        <figcaption>7750 Archer Rd, Justice, IL 60458</figcaption>
      </figure>
    </div>
  </header>

  <section id="programs" class="programs" aria-label="Chicago Fight Team training programs">
    <p class="section-label">Programs</p>
    <div class="program-grid">
      <article>
        <img src={`${imageBase}/bjj-training.jpeg`} alt="Brazilian Jiu-Jitsu training at Chicago Fight Team" loading="lazy" />
        <h4>Brazilian Jiu-Jitsu</h4>
        <p>Fundamentals, live training, self-defense, kids classes, and competition preparation.</p>
      </article>
      <article>
        <img src={`${imageBase}/mma-striking-class.png`} alt="MMA striking class at Chicago Fight Team" loading="lazy" />
        <h4>MMA</h4>
        <p>Striking, grappling, wrestling, conditioning, and fight-team training.</p>
      </article>
      <article>
        <img src={`${imageBase}/muay-thai-training.jpeg`} alt="Muay Thai pad work at Chicago Fight Team" loading="lazy" />
        <h4>Muay Thai</h4>
        <p>Stand-up training, pad work, conditioning, and striking fundamentals.</p>
      </article>
    </div>
  </section>

  <section id="coaches" class="coach-section" aria-labelledby="coaches-heading">
    <div class="coach-copy">
      <p class="section-label">Leadership</p>
      <h3 id="coaches-heading">Roberto Ramirez and Chicago Fight Team</h3>
      <p>
        Founded by Roberto Ramirez, Chicago Fight Team has trained amateur and
        professional fighters for more than two decades.
      </p>
    </div>
    <div class="coach-grid" aria-label="Chicago Fight Team coaches">
      <article>
        <img src={`${imageBase}/roberto-ramirez.png`} alt="Roberto Ramirez" loading="lazy" />
        <h4>Roberto Ramirez</h4>
        <p>Founder & Head Coach</p>
      </article>
      <article>
        <img src={`${imageBase}/nicasio-sanchez.jpeg`} alt="Nicasio Sanchez" loading="lazy" />
        <h4>Nicasio Sanchez</h4>
        <p>Jiu-Jitsu Black Belt Coach</p>
      </article>
    </div>
  </section>

  <section class="fighters" aria-label="Chicago Fight Team fighters">
    <p class="section-label">Fighters</p>
    <div class="fighter-grid">
      <article>
        <img src={`${imageBase}/belal-muhammad.jpeg`} alt="Belal Muhammad associated with Chicago Fight Team" loading="lazy" />
        <h4>Belal Muhammad</h4>
        <p>Former UFC Welterweight Champion</p>
      </article>
      <article>
        <img src={`${imageBase}/louis-taylor.jpeg`} alt="Louis Taylor" loading="lazy" />
        <h4>Louis Taylor</h4>
        <p>PFL Middleweight Champion</p>
      </article>
      <article>
        <img src={`${imageBase}/horacio-gutierrez-ufc.jpeg`} alt="Horacio Gutierrez at a UFC weigh-in" loading="lazy" />
        <h4>Horacio Gutierrez</h4>
        <p>UFC Veteran</p>
      </article>
    </div>
  </section>

  <section class="social-proof" aria-labelledby="social-heading">
    <p class="section-label">Instagram</p>
    <a id="social-heading" class="social-link" href="https://www.instagram.com/chicagofightteam/">@chicagofightteam</a>
    <div class="social-embed">
      <iframe
        src="https://www.instagram.com/chicagofightteam/embed"
        title="Chicago Fight Team Instagram profile"
        loading="lazy"
      ></iframe>
    </div>
  </section>

  <section class="video-location" aria-label="Chicago Fight Team video and location">
    <p class="section-label">Video</p>
    <div class="video-wrap">
      <iframe
        src="https://www.youtube.com/embed/NGYfM8yBRB0?controls=1"
        title="Chicago Fight Team Jiu-Jitsu video"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <section class="location-section" aria-label="Chicago Fight Team location">
    <p class="section-label">Location</p>
    <div class="location-panel">
      <div>
        <h3>Chicago Fight Team</h3>
        <p>7750 Archer Rd, Justice, IL 60458</p>
        <a href="tel:+17738855700">1 (773) 885-5700</a>
      </div>
      <iframe
        class="map-frame"
        src="https://www.google.com/maps?q=Chicago%20Fight%20Team%2C%207750%20Archer%20Rd%2C%20Justice%2C%20IL%2060458&output=embed"
        title="Map to Chicago Fight Team"
        loading="lazy"
      ></iframe>
    </div>
  </section>
</section>

<style>
  .cft-preview {
    --cft-ink: #f6f2e9;
    --cft-muted: #d6cec2;
    --cft-panel: #171717;
    --cft-line: rgba(246, 242, 233, 0.16);
    --cft-red: #e04436;
    margin: 36px 0 46px;
    overflow: hidden;
    border: 1px solid #23201d;
    border-radius: 8px;
    background: #080808;
    color: var(--cft-ink);
    box-shadow: 0 26px 70px rgba(16, 18, 17, 0.22);
  }

  .cft-preview *,
  .cft-preview *::before,
  .cft-preview *::after {
    box-sizing: border-box;
  }

  .cft-preview.is-standalone {
    min-height: 100vh;
    margin: 0;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .preview-frame {
    min-height: 510px;
    padding: 22px;
    background:
      linear-gradient(180deg, rgba(8, 8, 8, 0) 48%, rgba(10, 10, 9, 0.62) 78%, rgba(8, 8, 8, 0.9) 100%),
      radial-gradient(circle at 72% 90%, rgba(52, 59, 61, 0.22), rgba(8, 8, 8, 0) 34%),
      linear-gradient(90deg, rgba(8, 8, 8, 0.97) 0%, rgba(8, 8, 8, 0.88) 48%, rgba(8, 8, 8, 0.42) 100%),
      url("/images/work/chicago-fight-team/training-room-wide.jpeg") center / cover;
  }

  .preview-nav,
  .hero-grid,
  .programs,
  .coach-section,
  .fighters,
  .social-proof,
  .video-location,
  .location-section {
    width: min(100%, 1120px);
    margin-inline: auto;
  }

  .preview-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 70px;
    border-bottom: 1px solid var(--cft-line);
  }

  .brand,
  .hero-actions,
  .nav-links,
  .nav-cta,
  .mobile-menu summary {
    display: inline-flex;
    align-items: center;
  }

  .brand {
    color: var(--cft-ink);
    text-decoration: none;
  }

  .brand img {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
  }

  .nav-links {
    gap: 20px;
    color: #eee6da;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .mobile-menu {
    display: none;
    position: relative;
    margin-left: auto;
  }

  .mobile-menu summary {
    width: 34px;
    height: 34px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    border: 0;
    padding: 0;
    cursor: pointer;
    list-style: none;
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu summary span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--cft-ink);
  }

  .mobile-menu div {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    z-index: 2;
    display: grid;
    min-width: 162px;
    border: 1px solid var(--cft-line);
    border-radius: 4px;
    background: #080808;
  }

  .mobile-menu a {
    padding: 11px 13px;
    color: var(--cft-ink);
    font-size: 0.76rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  .mobile-menu a + a {
    border-top: 1px solid var(--cft-line);
  }

  .nav-cta,
  .hero-actions a,
  .location-panel a {
    min-height: 44px;
    border: 1px solid rgba(246, 242, 233, 0.36);
    border-radius: 4px;
    padding: 11px 16px;
    color: var(--cft-ink);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  .cft-preview .nav-cta,
  .cft-preview .hero-actions a,
  .cft-preview .location-panel a {
    color: var(--cft-ink);
  }

  .hero-actions a:first-child {
    border-color: var(--cft-red);
    background: var(--cft-red);
  }

  .nav-cta {
    background: transparent;
    font-size: 0.76rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.82fr) minmax(420px, 1fr);
    align-items: center;
    gap: 42px;
    padding: 62px 0 28px;
  }

  .hero-copy h2 {
    max-width: 540px;
    margin: 0 0 18px;
    color: var(--cft-ink);
    font-size: clamp(2.25rem, 4.2vw, 3.95rem);
    font-weight: 620;
    line-height: 1.04;
    letter-spacing: 0;
    text-transform: none;
  }

  .hero-copy p {
    max-width: 38ch;
    margin: 0 0 24px;
    color: #eee6da;
    font-size: clamp(1rem, 1.45vw, 1.08rem);
    line-height: 1.6;
  }

  .kicker {
    margin: 0 0 12px;
    color: #eee6da;
    font-size: 0.72rem;
    font-weight: 560;
    text-transform: uppercase;
  }

  .section-label {
    margin: 0 0 14px;
    color: #bfb7ad;
    font-size: 0.7rem;
    font-weight: 560;
    text-transform: uppercase;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-media {
    margin: 0;
  }

  .hero-media img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    object-fit: cover;
    object-position: center 42%;
    filter: grayscale(1) contrast(1.08);
  }

  .hero-media figcaption {
    margin-top: 10px;
    color: #eee6da;
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .programs,
  .coach-section,
  .fighters,
  .social-proof,
  .video-location,
  .location-section {
    padding: 48px 22px;
  }

  .programs {
    border-top: 1px solid var(--cft-line);
  }

  .coach-copy h3,
  .location-panel h3 {
    margin: 0 0 16px;
    color: var(--cft-ink);
    font-size: clamp(1.55rem, 3vw, 2.45rem);
    line-height: 1.06;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .program-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .program-grid article {
    overflow: hidden;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    background: var(--cft-panel);
  }

  .program-grid img {
    display: block;
    width: 100%;
    aspect-ratio: 5 / 3;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
  }

  .program-grid h4,
  .program-grid p {
    margin-inline: 16px;
  }

  .program-grid h4 {
    margin-top: 16px;
    margin-bottom: 8px;
    color: var(--cft-ink);
    font-size: 1.02rem;
    text-transform: uppercase;
  }

  .program-grid p,
  .coach-copy p,
  .coach-grid p,
  .fighter-grid p,
  .social-copy p,
  .location-panel p {
    color: #ddd5c9;
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .program-grid p {
    margin-bottom: 18px;
  }

  .coach-section {
    display: grid;
    grid-template-columns: minmax(260px, 0.72fr) minmax(0, 1fr);
    align-items: stretch;
    gap: 34px;
    border-top: 1px solid var(--cft-line);
  }

  .coach-copy {
    align-self: center;
  }

  .coach-copy p {
    max-width: 520px;
  }

  .coach-copy h3 {
    font-weight: 620;
    text-transform: none;
  }

  .coach-grid,
  .fighter-grid {
    display: grid;
    gap: 10px;
  }

  .coach-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .coach-grid article,
  .fighter-grid article {
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    background: var(--cft-panel);
  }

  .coach-grid img,
  .fighter-grid img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    filter: grayscale(1) contrast(1.08);
  }

  .fighters {
    border-top: 1px solid var(--cft-line);
  }

  .fighter-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .coach-grid h4,
  .coach-grid p,
  .fighter-grid h4,
  .fighter-grid p {
    margin-inline: 16px;
  }

  .coach-grid h4,
  .fighter-grid h4 {
    margin-top: 16px;
    margin-bottom: 6px;
    color: var(--cft-ink);
    font-size: 0.98rem;
    text-transform: uppercase;
  }

  .coach-grid p,
  .fighter-grid p {
    margin-top: 0;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }

  .social-proof {
    border-top: 1px solid var(--cft-line);
  }

  .social-link {
    display: inline-flex;
    margin-bottom: 14px;
    color: #eee6da;
    font-size: 0.82rem;
    font-weight: 760;
    text-decoration: none;
    text-transform: uppercase;
    overflow-wrap: anywhere;
  }

  .social-proof h3 {
    font-weight: 620;
    text-transform: none;
    overflow-wrap: anywhere;
  }

  .social-embed {
    overflow: hidden;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    background: #050505;
  }

  .social-embed iframe {
    display: block;
    width: 100%;
    min-height: 420px;
    border: 0;
  }

  .video-location {
    border-top: 1px solid var(--cft-line);
  }

  .video-wrap {
    overflow: hidden;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    background: #000;
  }

  .video-wrap iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    border: 0;
  }

  .location-panel {
    display: grid;
    gap: 18px;
  }

  .location-panel a {
    margin-top: 16px;
  }

  .map-frame {
    display: block;
    width: 100%;
    min-height: 320px;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    filter: grayscale(1) contrast(1.02) brightness(0.9);
  }

  @media (max-width: 840px) {
    .preview-frame {
      min-height: auto;
      padding: 16px;
    }

    .nav-links {
      display: none;
    }

    .mobile-menu {
      display: block;
    }

    .preview-nav > .nav-cta {
      display: none;
    }

    .hero-grid,
    .location-panel {
      grid-template-columns: 1fr;
    }

    .coach-section {
      grid-template-columns: 1fr;
    }

    .hero-grid {
      padding-top: 54px;
    }

    .hero-media img {
      aspect-ratio: 16 / 11;
    }

    .program-grid,
    .coach-grid,
    .fighter-grid {
      grid-template-columns: 1fr;
    }

    .social-embed iframe {
      min-height: 360px;
    }

  }

  @media (max-width: 560px) {
    .cft-preview {
      margin-inline: -6px;
    }

    .preview-nav {
      align-items: center;
      flex-direction: row;
      padding-bottom: 14px;
    }

    .hero-copy h2 {
      font-size: 2.05rem;
    }

    .programs,
    .coach-section,
    .fighters,
    .social-proof,
    .video-location,
    .location-section {
      padding: 34px 16px;
    }
  }
</style>
