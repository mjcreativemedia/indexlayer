---
export interface Props {
  mode?: "article" | "standalone";
}

const imageBase = "/images/work/chicago-fight-team";
const { mode = "article" } = Astro.props;
---

<section class:list={["cft-preview", mode === "standalone" && "is-standalone"]} aria-label="Chicago Fight Team homepage rebuild preview">
  <header class="preview-frame">
    <nav class="preview-nav" aria-label="Preview navigation">
      <a class="brand" href="https://chicagofightteam.org/">
        <img src={`${imageBase}/cft-logo.jpeg`} alt="" loading="lazy" />
      </a>
      <div class="nav-links" aria-hidden="true">
        <span>Programs</span>
        <span>Coaches</span>
        <span>Schedule</span>
      </div>
      <a class="nav-cta" href="https://chicagofightteam.org/">Start</a>
    </nav>

    <div class="hero-grid">
      <div class="hero-copy">
        <p class="kicker">MMA • BJJ • Muay Thai</p>
        <h2>Chicago Fight Team</h2>
        <p>
          Home of world champions with more than 20 years of fight training and
          competition prep in Chicago.
        </p>
        <div class="hero-actions">
          <a href="tel:+17738855700">Call</a>
          <a href="https://www.google.com/maps/place/Chicago+Fight+Team/">Visit Gym</a>
        </div>
      </div>
      <figure class="hero-media">
        <img src={`${imageBase}/training-room-wide.jpeg`} alt="Chicago Fight Team training room" loading="lazy" />
        <figcaption>7750 Archer Rd, Justice, IL 60458</figcaption>
      </figure>
    </div>
  </header>

  <section class="programs" aria-label="Chicago Fight Team training programs">
    <div class="program-grid">
      <article>
        <img src={`${imageBase}/jiu-jitsu-training.jpeg`} alt="Jiu-Jitsu training at Chicago Fight Team" loading="lazy" />
        <h4>Brazilian Jiu-Jitsu</h4>
        <p>Fundamentals, live training, self-defense, kids classes, and competition preparation.</p>
      </article>
      <article>
        <img src={`${imageBase}/cloud-training.jpeg`} alt="Chicago Fight Team striking and conditioning training" loading="lazy" />
        <h4>MMA</h4>
        <p>Striking, grappling, wrestling, conditioning, and fight-team training.</p>
      </article>
      <article>
        <img src={`${imageBase}/about-header.jpeg`} alt="Chicago Fight Team Muay Thai training environment" loading="lazy" />
        <h4>Muay Thai</h4>
        <p>Stand-up training, pad work, conditioning, and striking fundamentals.</p>
      </article>
    </div>
  </section>

  <section class="fighter-proof" aria-labelledby="proof-heading">
    <div class="proof-people" aria-label="Featured fighter and coach credibility">
      <figure>
        <img src={`${imageBase}/belal-muhammad.jpeg`} alt="Belal Muhammad associated with Chicago Fight Team" loading="lazy" />
        <figcaption>Belal Muhammad</figcaption>
      </figure>
      <figure>
        <img src={`${imageBase}/horacio-gutierrez.jpeg`} alt="Horacio Gutierrez" loading="lazy" />
        <figcaption>Horacio Gutierrez</figcaption>
      </figure>
      <figure>
        <img src={`${imageBase}/nicasio-sanchez.jpeg`} alt="Nicasio Sanchez" loading="lazy" />
        <figcaption>Nicasio Sanchez</figcaption>
      </figure>
    </div>
    <div class="proof-copy">
      <h3 id="proof-heading">Roberto Ramirez and Chicago Fight Team</h3>
      <p>
        Founded by Roberto Ramirez, Chicago Fight Team has trained amateur and
        professional fighters in Chicago for more than two decades.
      </p>
    </div>
  </section>

  <section class="social-proof" aria-labelledby="social-heading">
    <a id="social-heading" class="social-link" href="https://www.instagram.com/chicagofightteam/">@chicagofightteam</a>
    <div class="social-embed">
      <iframe
        src="https://www.instagram.com/chicagofightteam/embed"
        title="Chicago Fight Team Instagram profile"
        loading="lazy"
      ></iframe>
    </div>
  </section>

  <section class="video-location" aria-label="Chicago Fight Team video and location">
    <div class="video-wrap">
      <iframe
        src="https://www.youtube.com/embed/NGYfM8yBRB0?controls=1"
        title="Chicago Fight Team Jiu-Jitsu video"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
  </section>

  <section class="location-section" aria-label="Chicago Fight Team location">
    <div class="location-panel">
      <div>
        <h3>Chicago Fight Team</h3>
        <p>7750 Archer Rd, Justice, IL 60458</p>
        <a href="tel:+17738855700">1 (773) 885-5700</a>
      </div>
      <iframe
        class="map-frame"
        src="https://www.google.com/maps?q=Chicago%20Fight%20Team%2C%207750%20Archer%20Rd%2C%20Justice%2C%20IL%2060458&output=embed"
        title="Map to Chicago Fight Team"
        loading="lazy"
      ></iframe>
    </div>
  </section>
</section>

<style>
  .cft-preview {
    --cft-ink: #f6f2e9;
    --cft-muted: #d6cec2;
    --cft-panel: #171717;
    --cft-line: rgba(246, 242, 233, 0.16);
    --cft-red: #e04436;
    margin: 36px 0 46px;
    overflow: hidden;
    border: 1px solid #23201d;
    border-radius: 8px;
    background: #080808;
    color: var(--cft-ink);
    box-shadow: 0 26px 70px rgba(16, 18, 17, 0.22);
  }

  .cft-preview.is-standalone {
    min-height: 100vh;
    margin: 0;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .preview-frame {
    min-height: 560px;
    padding: 22px;
    background:
      linear-gradient(180deg, rgba(8, 8, 8, 0) 48%, rgba(10, 10, 9, 0.62) 78%, rgba(8, 8, 8, 0.9) 100%),
      radial-gradient(circle at 72% 90%, rgba(52, 59, 61, 0.22), rgba(8, 8, 8, 0) 34%),
      linear-gradient(90deg, rgba(8, 8, 8, 0.97) 0%, rgba(8, 8, 8, 0.88) 48%, rgba(8, 8, 8, 0.42) 100%),
      url("/images/work/chicago-fight-team/training-room-wide.jpeg") center / cover;
  }

  .preview-nav,
  .hero-grid,
  .programs,
  .fighter-proof,
  .social-proof,
  .video-location,
  .location-section {
    width: min(100%, 1120px);
    margin-inline: auto;
  }

  .preview-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 70px;
    border-bottom: 1px solid var(--cft-line);
  }

  .brand,
  .hero-actions,
  .nav-links,
  .nav-cta {
    display: inline-flex;
    align-items: center;
  }

  .brand {
    color: var(--cft-ink);
    text-decoration: none;
  }

  .brand img {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
  }

  .nav-links {
    gap: 20px;
    color: #eee6da;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .nav-cta,
  .hero-actions a,
  .location-panel a {
    min-height: 44px;
    border: 1px solid rgba(246, 242, 233, 0.36);
    border-radius: 4px;
    padding: 11px 16px;
    color: var(--cft-ink);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  .cft-preview .nav-cta,
  .cft-preview .hero-actions a,
  .cft-preview .location-panel a {
    color: var(--cft-ink);
  }

  .hero-actions a:first-child {
    border-color: var(--cft-red);
    background: var(--cft-red);
  }

  .nav-cta {
    background: transparent;
    font-size: 0.76rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(260px, 0.68fr);
    align-items: center;
    gap: 42px;
    padding: 74px 0 30px;
  }

  .hero-copy h2 {
    max-width: 540px;
    margin: 0 0 18px;
    color: var(--cft-ink);
    font-size: clamp(2.25rem, 4.2vw, 3.95rem);
    font-weight: 620;
    line-height: 1.04;
    letter-spacing: 0;
    text-transform: none;
  }

  .hero-copy p {
    max-width: 520px;
    margin: 0 0 24px;
    color: #eee6da;
    font-size: clamp(1rem, 1.45vw, 1.08rem);
    line-height: 1.6;
  }

  .kicker {
    margin: 0 0 12px;
    color: #eee6da;
    font-size: 0.8rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  .hero-actions {
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-media {
    margin: 0;
  }

  .hero-media img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    object-fit: cover;
    filter: grayscale(1) contrast(1.08);
  }

  .hero-media figcaption,
  .proof-people figcaption {
    margin-top: 10px;
    color: #eee6da;
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .programs,
  .fighter-proof,
  .social-proof,
  .video-location,
  .location-section {
    padding: 48px 22px;
  }

  .programs {
    border-top: 1px solid var(--cft-line);
  }

  .fighter-proof h3,
  .social-proof h3,
  .location-panel h3 {
    margin: 0 0 16px;
    color: var(--cft-ink);
    font-size: clamp(1.55rem, 3vw, 2.45rem);
    line-height: 1.06;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .program-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .program-grid article {
    overflow: hidden;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    background: var(--cft-panel);
  }

  .program-grid img {
    display: block;
    width: 100%;
    aspect-ratio: 5 / 3;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
  }

  .program-grid h4,
  .program-grid p {
    margin-inline: 16px;
  }

  .program-grid h4 {
    margin-top: 16px;
    margin-bottom: 8px;
    color: var(--cft-ink);
    font-size: 1.02rem;
    text-transform: uppercase;
  }

  .program-grid p,
  .proof-copy p,
  .social-copy p,
  .location-panel p {
    color: #ddd5c9;
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .program-grid p {
    margin-bottom: 18px;
  }

  .fighter-proof {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.78fr);
    align-items: center;
    gap: 34px;
    border-top: 1px solid var(--cft-line);
  }

  .proof-copy p {
    max-width: 520px;
  }

  .fighter-proof h3 {
    font-weight: 620;
    text-transform: none;
  }

  .proof-people {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .proof-people figure {
    margin: 0;
  }

  .proof-people img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    object-fit: cover;
    filter: grayscale(1) contrast(1.08);
  }

  .social-proof {
    border-top: 1px solid var(--cft-line);
  }

  .social-link {
    display: inline-flex;
    margin-bottom: 14px;
    color: #eee6da;
    font-size: 0.82rem;
    font-weight: 760;
    text-decoration: none;
    text-transform: uppercase;
    overflow-wrap: anywhere;
  }

  .social-proof h3 {
    font-weight: 620;
    text-transform: none;
    overflow-wrap: anywhere;
  }

  .social-embed {
    overflow: hidden;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    background: #050505;
  }

  .social-embed iframe {
    display: block;
    width: 100%;
    min-height: 420px;
    border: 0;
  }

  .video-location {
    border-top: 1px solid var(--cft-line);
  }

  .video-wrap {
    overflow: hidden;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    background: #000;
  }

  .video-wrap iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    border: 0;
  }

  .location-panel {
    display: grid;
    gap: 18px;
  }

  .location-panel a {
    margin-top: 16px;
  }

  .map-frame {
    display: block;
    width: 100%;
    min-height: 320px;
    border: 1px solid var(--cft-line);
    border-radius: 6px;
    filter: grayscale(1) contrast(1.02) brightness(0.9);
  }

  @media (max-width: 840px) {
    .preview-frame {
      min-height: auto;
      padding: 16px;
    }

    .nav-links {
      display: none;
    }

    .hero-grid,
    .fighter-proof,
    .location-panel {
      grid-template-columns: 1fr;
    }

    .hero-grid {
      padding-top: 54px;
    }

    .hero-media img {
      aspect-ratio: 16 / 10;
    }

    .program-grid,
    .proof-people {
      grid-template-columns: 1fr;
    }

    .social-embed iframe {
      min-height: 360px;
    }

  }

  @media (max-width: 560px) {
    .cft-preview {
      margin-inline: -6px;
    }

    .preview-nav {
      align-items: flex-start;
      flex-direction: column;
      padding-bottom: 14px;
    }

    .hero-copy h2 {
      font-size: 2.05rem;
    }

    .programs,
    .fighter-proof,
    .social-proof,
    .video-location,
    .location-section {
      padding: 34px 16px;
    }
  }
</style>
