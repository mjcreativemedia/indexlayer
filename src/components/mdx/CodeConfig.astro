---
export interface Props {
  label?: string;
}

const { label = "Config note" } = Astro.props;
---

<section class="code-config">
  <span>{label}</span>
  <slot />
</section>

<style>
  .code-config {
    margin: 30px 0;
    border: 1px solid var(--line);
    background: #111713;
    color: white;
    overflow: hidden;
  }

  span {
    display: block;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    padding: 10px 14px;
    color: #cfe5d5;
    font-size: 0.82rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .code-config :global(pre) {
    margin: 0;
    padding: 18px;
    overflow-x: auto;
    background: transparent;
  }
</style>
